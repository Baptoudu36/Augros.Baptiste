    "# ============================================================================\n",
    "# TIME WINDOW EXTRACTION FUNCTIONS\n",
    "# ============================================================================\n",
    "\n",
    "def extract_baseline(df, time_col='time_sec', exercise_start_time=None, \n",
    "                     baseline_duration=30, baseline_end_offset=0):\n",
    "    \"\"\"\n",
    "    Extract baseline (rest) period before exercise start.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : DataFrame\n",
    "        Data with time columns\n",
    "    time_col : str\n",
    "        Name of time column (in seconds)\n",
    "    exercise_start_time : float\n",
    "        Exercise start time (seconds). If None, estimated automatically.\n",
    "    baseline_duration : float\n",
    "        Baseline window duration (seconds, default=30)\n",
    "    baseline_end_offset : float\n",
    "        Offset before exercise start (seconds, default=0)\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    DataFrame containing only baseline data\n",
    "    dict with information about extracted window\n",
    "    \"\"\"\n",
    "    if exercise_start_time is None:\n",
    "        # Estimate exercise start (e.g., when VO2 increases significantly)\n",
    "        # For simplicity, use 60s as default start\n",
    "        exercise_start_time = 60\n",
    "        print(f\"  ⚠ Exercise start time not specified, using {exercise_start_time}s by default\")\n",
    "    \n",
    "    # Calculate baseline window\n",
    "    baseline_end = exercise_start_time - baseline_end_offset\n",
    "    baseline_start = baseline_end - baseline_duration\n",
    "    \n",
    "    # Extract data\n",
    "    mask = (df[time_col] >= baseline_start) & (df[time_col] < baseline_end)\n",
    "    baseline_data = df[mask].copy()\n",
    "    \n",
    "    info = {\n",
    "        'start_time': baseline_start,\n",
    "        'end_time': baseline_end,\n",
    "        'duration': baseline_duration,\n",
    "        'n_samples': len(baseline_data)\n",
    "    }\n",
    "    \n",
    "    print(f\"✓ Baseline extracted: {baseline_start:.1f}s - {baseline_end:.1f}s ({len(baseline_data)} samples)\")\n",
    "    \n",
    "    return baseline_data, info\n",
    "\n",
    "\n",
    "def extract_steady_state(df, time_col='time_sec', exercise_start_time=None,\n",
    "                        steady_start_offset=120, steady_end_offset=270):\n",
    "    \"\"\"\n",
    "    Extract steady-state period during exercise.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : DataFrame\n",
    "        Data with time columns\n",
    "    time_col : str\n",
    "        Name of time column (in seconds)\n",
    "    exercise_start_time : float\n",
    "        Exercise start time (seconds)\n",
    "    steady_start_offset : float\n",
    "        Start of stable window after exercise start (seconds, default=120 for 2:00)\n",
    "    steady_end_offset : float\n",
    "        End of stable window after exercise start (seconds, default=270 for 4:30)\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    DataFrame containing only steady-state data\n",
    "    dict with information about extracted window\n",
    "    \"\"\"\n",
    "    if exercise_start_time is None:\n",
    "        exercise_start_time = 60\n",
    "        print(f\"  ⚠ Exercise start time not specified, using {exercise_start_time}s by default\")\n",
    "    \n",
    "    # Calculate steady-state window\n",
    "    steady_start = exercise_start_time + steady_start_offset\n",
    "    steady_end = exercise_start_time + steady_end_offset\n",
    "    \n",
    "    # Extract data\n",
    "    mask = (df[time_col] >= steady_start) & (df[time_col] < steady_end)\n",
    "    steady_data = df[mask].copy()\n",
    "    \n",
    "    info = {\n",
    "        'start_time': steady_start,\n",
    "        'end_time': steady_end,\n",
    "        'duration': steady_end_offset - steady_start_offset,\n",
    "        'n_samples': len(steady_data)\n",
    "    }\n",
    "    \n",
    "    print(f\"✓ Steady-state extracted: {steady_start:.1f}s - {steady_end:.1f}s ({len(steady_data)} samples)\")\n",
    "    \n",
    "    return steady_data, info\n",
    "\n",
    "\n",
    "def compute_window_stats(df, columns, prefix=''):\n",
    "    \"\"\"\n",
    "    Calculate statistics (mean, standard deviation) for a data window.\n",
    "    \n",
    "    Returns a dictionary with results.\n",
    "    \"\"\"\n",
    "    stats = {}\n",
    "    \n",
    "    for col in columns:\n",
    "        if col in df.columns:\n",
    "            data = df[col].dropna()\n",
    "            if len(data) > 0:\n",
    "                stats[f'{prefix}{col}_mean'] = data.mean()\n",
    "                stats[f'{prefix}{col}_std'] = data.std()\n",
    "                stats[f'{prefix}{col}_n'] = len(data)\n",
    "    \n",
    "    return stats\n",
    "\n",
    "\n",
    "print(\"✓ Time window extraction functions defined\")\n"
   ]
