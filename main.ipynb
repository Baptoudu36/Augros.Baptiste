   "source": [
    "# ============================================================================\n",
    "# FRIEDMAN NON-PARAMETRIC TESTS (A/B/C)\n",
    "# ============================================================================\n",
    "\n",
    "print(\"=\" * 80)\n",
    "print(\"FRIEDMAN TESTS (NON-PARAMETRIC ROBUSTNESS CHECK)\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "friedman_targets = [\n",
    "    \"VO2_ml_min\",\n",
    "    \"HR_bpm\",\n",
    "    \"SmO2_Quad\",\n",
    "    \"SmO2_Calf\",\n",
    "    \"Mean_Peak_Force\",\n",
    "]\n",
    "\n",
    "friedman_rows = []\n",
    "\n",
    "if \"block_level_df\" in globals() and isinstance(block_level_df, pd.DataFrame) and not block_level_df.empty:\n",
    "    for var in friedman_targets:\n",
    "        if var not in block_level_df.columns:\n",
    "            friedman_rows.append({\n",
    "                \"variable\": var,\n",
    "                \"chi2\": np.nan,\n",
    "                \"p_value\": np.nan,\n",
    "                \"n_repeats\": 0,\n",
    "                \"status\": \"missing_variable\",\n",
    "            })\n",
    "            continue\n",
    "\n",
    "        cond_vectors = {}\n",
    "        for cond in [\"A\", \"B\", \"C\"]:\n",
    "            vals = (\n",
    "                block_level_df.loc[block_level_df[\"shoe_code\"] == cond, var]\n",
    "                .dropna()\n",
    "                .astype(float)\n",
    "                .values\n",
    "            )\n",
    "            cond_vectors[cond] = vals\n",
    "\n",
    "        n_repeats = min(len(cond_vectors[\"A\"]), len(cond_vectors[\"B\"]), len(cond_vectors[\"C\"]))\n",
    "\n",
    "        if n_repeats >= 2:\n",
    "            try:\n",
    "                stat, p_val = stats.friedmanchisquare(\n",
    "                    cond_vectors[\"A\"][:n_repeats],\n",
    "                    cond_vectors[\"B\"][:n_repeats],\n",
    "                    cond_vectors[\"C\"][:n_repeats],\n",
    "                )\n",
    "                status = \"ok\"\n",
    "            except Exception:\n",
    "                stat, p_val = np.nan, np.nan\n",
    "                status = \"failed\"\n",
    "        else:\n",
    "            stat, p_val = np.nan, np.nan\n",
    "            status = \"insufficient_repeated_blocks\"\n",
    "\n",
    "        friedman_rows.append({\n",
    "            \"variable\": var,\n",
    "            \"chi2\": stat,\n",
    "            \"p_value\": p_val,\n",
    "            \"n_repeats\": n_repeats,\n",
    "            \"status\": status,\n",
    "        })\n",
    "else:\n",
    "    print(\"⚠ block_level_df not available. Run consolidation/statistical cells first.\")\n",
    "\n",
    "friedman_results_df = pd.DataFrame(friedman_rows)\n",
    "\n",
    "if not friedman_results_df.empty:\n",
    "    print(friedman_results_df.to_string(index=False))\n",
    "else:\n",
    "    print(\"No Friedman results generated.\")"
   ]
