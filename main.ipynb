   "source": [
    "# ============================================================================\n",
    "# TASK 3 : CONDITION-BASED ADVANCED PHYSIOLOGICAL ANALYSIS (NOTEBOOK CORE)\n",
    "# ============================================================================\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from scipy import stats\n",
    "from statsmodels.stats.anova import AnovaRM\n",
    "\n",
    "CONDITION_MAP = {\n",
    "    \"A\": [1, 6],\n",
    "    \"B\": [2, 5],\n",
    "    \"C\": [3, 4],\n",
    "}\n",
    "\n",
    "\n",
    "def _get_col(df, candidates):\n",
    "    \"\"\"Return first matching column name from candidate list.\"\"\"\n",
    "    lower_map = {c.lower(): c for c in df.columns}\n",
    "    for cand in candidates:\n",
    "        if cand in df.columns:\n",
    "            return cand\n",
    "        if cand.lower() in lower_map:\n",
    "            return lower_map[cand.lower()]\n",
    "    return None\n",
    "\n",
    "\n",
    "def _extract_window(df, start_sec, end_sec):\n",
    "    \"\"\"Extract [start_sec, end_sec) window from dataframe using time_sec.\"\"\"\n",
    "    if \"time_sec\" not in df.columns:\n",
    "        raise ValueError(\"Expected 'time_sec' column.\")\n",
    "    out = df[(df[\"time_sec\"] >= start_sec) & (df[\"time_sec\"] < end_sec)].copy()\n",
    "    return out.reset_index(drop=True)\n",
    "\n",
    "\n",
    "def compute_auc(signal, time):\n",
    "    \"\"\"Compute trapezoidal AUC.\"\"\"\n",
    "    y = np.asarray(signal, dtype=float)\n",
    "    t = np.asarray(time, dtype=float)\n",
    "    valid = np.isfinite(y) & np.isfinite(t)\n",
    "    if valid.sum() < 2:\n",
    "        return np.nan\n",
    "    return float(np.trapz(y[valid], t[valid]))\n",
    "\n",
    "\n",
    "def compute_slope(signal, time):\n",
    "    \"\"\"Compute linear slope using linear regression.\"\"\"\n",
    "    y = np.asarray(signal, dtype=float)\n",
    "    t = np.asarray(time, dtype=float)\n",
    "    valid = np.isfinite(y) & np.isfinite(t)\n",
    "    if valid.sum() < 3:\n",
    "        return np.nan\n",
    "    slope, _, _, _, _ = stats.linregress(t[valid], y[valid])\n",
    "    return float(slope)\n",
    "\n",
    "\n",
    "def compare_baselines(initial_baseline, final_baseline):\n",
    "    \"\"\"Compute baseline initial-final mean differences for VO2, TSI, HHb.\"\"\"\n",
    "    metrics = [\"VO2\", \"TSI\", \"HHb\"]\n",
    "    rows = []\n",
    "    for metric in metrics:\n",
    "        ini = initial_baseline.get(metric, np.nan)\n",
    "        fin = final_baseline.get(metric, np.nan)\n",
    "        rows.append(\n",
    "            {\n",
    "                \"Metric\": metric,\n",
    "                \"Baseline_Initial\": ini,\n",
    "                \"Baseline_Final\": fin,\n",
    "                \"Delta_Final_minus_Initial\": fin - ini,\n",
    "            }\n",
    "        )\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "\n",
    "def time_to_steady_state(signal, time, tolerance=0.05, sustain_sec=20):\n",
    "    \"\"\"Estimate time to steady-state as first sustained entry within tolerance band.\"\"\"\n",
    "    y = np.asarray(signal, dtype=float)\n",
    "    t = np.asarray(time, dtype=float)\n",
    "    valid = np.isfinite(y) & np.isfinite(t)\n",
    "    if valid.sum() < 10:\n",
    "        return np.nan\n",
    "\n",
    "    y = y[valid]\n",
    "    t = t[valid]\n",
    "    plateau = np.nanmean(y[-max(5, int(len(y) * 0.2)):])\n",
    "    band = tolerance * max(abs(plateau), 1e-6)\n",
    "\n",
    "    dt = np.median(np.diff(t)) if len(t) > 1 else np.nan\n",
    "    if not np.isfinite(dt) or dt <= 0:\n",
    "        return np.nan\n",
    "    n_sustain = max(1, int(sustain_sec / dt))\n",
    "\n",
    "    within = np.abs(y - plateau) <= band\n",
    "    for i in range(0, len(within) - n_sustain + 1):\n",
    "        if np.all(within[i:i + n_sustain]):\n",
    "            return float(t[i] - t[0])\n",
    "    return np.nan\n",
    "\n",
    "\n",
    "def compute_recovery_slope(signal, time):\n",
    "    \"\"\"Compute slope during recovery phases.\"\"\"\n",
    "    return compute_slope(signal, time)\n",
    "\n",
    "\n",
    "required_vars = [\n",
    "    \"k5_data\",\n",
    "    \"nirs_data\",\n",
    "    \"fp_data\",\n",
    "    \"TIMELINE\",\n",
    "    \"PROTOCOL\",\n",
    "    \"extract_steady_state_from_block\",\n",
    "]\n",
    "missing_vars = [name for name in required_vars if name not in globals()]\n",
    "if missing_vars:\n",
    "    raise RuntimeError(\"Missing variables. Run upstream cells first: \" + \", \".join(missing_vars))\n",
    "\n",
    "vo2_col_k5 = _get_col(k5_data, [\"VO2_ml_min\", \"VO2\"])\n",
    "tsi_col_nirs = _get_col(nirs_data, [\"TSI\", \"TSI_Quad\", \"SmO2_Quad\", \"SmO2\"])\n",
    "hhb_col_nirs = _get_col(nirs_data, [\"HHb\", \"HHb_Quad\", \"HHb (uM)\"])\n",
    "force_col_fp = _get_col(fp_data, [\"total_force_N\", \"force_N\", \"VerticalForce\"])\n",
    "\n",
    "if vo2_col_k5 is None:\n",
    "    raise ValueError(\"No VO2 column found in COSMED data.\")\n",
    "if tsi_col_nirs is None:\n",
    "    raise ValueError(\"No TSI-compatible column found in NIRS data.\")\n",
    "\n",
    "if hhb_col_nirs is None:\n",
    "    print(\"Warning: HHb column not found. HHb-based metrics will be NaN.\")\n",
    "if force_col_fp is None:\n",
    "    print(\"Warning: Force column not found. TSI-Force correlation will be NaN.\")\n",
    "\n",
    "\n",
    "block_rows = []\n",
    "for block in range(1, PROTOCOL[\"n_blocks\"] + 1):\n",
    "    run_key = f\"run_{block}\"\n",
    "    rec_key = f\"recovery_{block}\"\n",
    "\n",
    "    run_info = TIMELINE[run_key]\n",
    "    rec_info = TIMELINE.get(rec_key)\n",
    "\n",
    "    run_start = run_info[\"start\"]\n",
    "    run_end = run_info[\"end\"]\n",
    "\n",
    "    # Full block windows for AUC / slopes.\n",
    "    k5_run = _extract_window(k5_data, run_start, run_end)\n",
    "    nirs_run = _extract_window(nirs_data, run_start, run_end)\n",
    "    fp_run = _extract_window(fp_data, run_start, run_end)\n",
    "\n",
    "    # Steady-state windows for condition means.\n",
    "    k5_ss, _ = extract_steady_state_from_block(k5_data, run_start)\n",
    "    nirs_ss, _ = extract_steady_state_from_block(nirs_data, run_start)\n",
    "\n",
    "    vo2_run = pd.to_numeric(k5_run[vo2_col_k5], errors=\"coerce\")\n",
    "    tsi_run = pd.to_numeric(nirs_run[tsi_col_nirs], errors=\"coerce\")\n",
    "    hhb_run = pd.to_numeric(nirs_run[hhb_col_nirs], errors=\"coerce\") if hhb_col_nirs else pd.Series(dtype=float)\n",
    "    force_run = pd.to_numeric(fp_run[force_col_fp], errors=\"coerce\") if force_col_fp else pd.Series(dtype=float)\n",
    "\n",
    "    vo2_ss = pd.to_numeric(k5_ss[vo2_col_k5], errors=\"coerce\")\n",
    "    tsi_ss = pd.to_numeric(nirs_ss[tsi_col_nirs], errors=\"coerce\")\n",
    "    hhb_ss = pd.to_numeric(nirs_ss[hhb_col_nirs], errors=\"coerce\") if hhb_col_nirs else pd.Series(dtype=float)\n",
    "\n",
    "    vo2_t = pd.to_numeric(k5_run[\"time_sec\"], errors=\"coerce\")\n",
    "    tsi_t = pd.to_numeric(nirs_run[\"time_sec\"], errors=\"coerce\")\n",
    "    hhb_t = tsi_t\n",
    "\n",
    "    row = {\n",
    "        \"block\": block,\n",
    "        \"condition\": run_info[\"shoe_code\"],\n",
    "        \"VO2_mean\": float(np.nanmean(vo2_ss)) if len(vo2_ss) else np.nan,\n",
    "        \"TSI_mean\": float(np.nanmean(tsi_ss)) if len(tsi_ss) else np.nan,\n",
    "        \"HHb_mean\": float(np.nanmean(hhb_ss)) if len(hhb_ss) else np.nan,\n",
    "        \"VO2_auc\": compute_auc(vo2_run, vo2_t),\n",
    "        \"TSI_auc\": compute_auc(tsi_run, tsi_t),\n",
    "        \"HHb_auc\": compute_auc(hhb_run, hhb_t),\n",
    "        \"TSI_slope\": compute_slope(tsi_run, tsi_t),\n",
    "        \"HHb_slope\": compute_slope(hhb_run, hhb_t),\n",
    "        \"Time_to_steady_state_sec\": time_to_steady_state(vo2_run, vo2_t),\n",
    "        \"Force_mean\": float(np.nanmean(force_run)) if len(force_run) else np.nan,\n",
    "    }\n",
    "\n",
    "    if rec_info is not None:\n",
    "        rec_start = rec_info[\"start\"]\n",
    "        rec_end = rec_info[\"end\"]\n",
    "        nirs_rec = _extract_window(nirs_data, rec_start, rec_end)\n",
    "        tsi_rec = pd.to_numeric(nirs_rec[tsi_col_nirs], errors=\"coerce\")\n",
    "        hhb_rec = pd.to_numeric(nirs_rec[hhb_col_nirs], errors=\"coerce\") if hhb_col_nirs else pd.Series(dtype=float)\n",
    "        t_rec = pd.to_numeric(nirs_rec[\"time_sec\"], errors=\"coerce\")\n",
    "\n",
    "        row[\"TSI_recovery_slope\"] = compute_recovery_slope(tsi_rec, t_rec)\n",
    "        row[\"HHb_recovery_slope\"] = compute_recovery_slope(hhb_rec, t_rec)\n",
    "    else:\n",
    "        row[\"TSI_recovery_slope\"] = np.nan\n",
    "        row[\"HHb_recovery_slope\"] = np.nan\n",
    "\n",
    "    block_rows.append(row)\n",
    "\n",
    "block_metrics_df = pd.DataFrame(block_rows).sort_values(\"block\").reset_index(drop=True)\n",
    "print(\"Block-level advanced metrics:\")\n",
    "display(block_metrics_df)\n",
    "\n",
    "\n",
    "# Condition-level means from ABCCBA paired blocks.\n",
    "cond_rows = []\n",
    "for cond, blocks in CONDITION_MAP.items():\n",
    "    sub = block_metrics_df[block_metrics_df[\"block\"].isin(blocks)]\n",
    "\n",
    "    vo2_mean_condition = sub[\"VO2_mean\"].mean()\n",
    "    tsi_mean_condition = sub[\"TSI_mean\"].mean()\n",
    "    hhb_mean_condition = sub[\"HHb_mean\"].mean()\n",
    "\n",
    "    mean_auc_condition = sub[\"VO2_auc\"].mean()\n",
    "    mean_slope_condition = sub[\"TSI_slope\"].mean()\n",
    "\n",
    "    vo2_std = sub[\"VO2_mean\"].std(ddof=1)\n",
    "    vo2_cv = (vo2_std / vo2_mean_condition * 100.0) if pd.notna(vo2_mean_condition) and vo2_mean_condition != 0 else np.nan\n",
    "\n",
    "    cond_rows.append(\n",
    "        {\n",
    "            \"Condition\": cond,\n",
    "            \"VO2_mean_condition\": vo2_mean_condition,\n",
    "            \"TSI_mean_condition\": tsi_mean_condition,\n",
    "            \"HHb_mean_condition\": hhb_mean_condition,\n",
    "            \"Mean_AUC\": mean_auc_condition,\n",
    "            \"Mean_Slope\": mean_slope_condition,\n",
    "            \"STD\": vo2_std,\n",
    "            \"CV\": vo2_cv,\n",
    "        }\n",
    "    )\n",
    "\n",
    "condition_summary_df = pd.DataFrame(cond_rows).sort_values(\"Condition\").reset_index(drop=True)\n",
    "\n",
    "condition_export_df = condition_summary_df.rename(columns={\"VO2_mean_condition\": \"Mean_VO2\"})[\n",
    "    [\"Condition\", \"Mean_VO2\", \"Mean_AUC\", \"Mean_Slope\", \"STD\", \"CV\"]\n",
    "]\n",
    "\n",
    "print(\"Condition summary:\")\n",
    "display(condition_summary_df)\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# Baseline comparison (Initial vs Final)\n",
    "# ---------------------------------------------------------------------------\n",
    "baseline_dur = PROTOCOL.get(\"baseline_duration\", 300)\n",
    "\n",
    "baseline_start = TIMELINE[\"baseline\"][\"start\"]\n",
    "baseline_end = TIMELINE[\"baseline\"][\"end\"]\n",
    "\n",
    "k5_initial = _extract_window(k5_data, baseline_start, baseline_end)\n",
    "nirs_initial = _extract_window(nirs_data, baseline_start, baseline_end)\n",
    "\n",
    "final_start_candidate = TIMELINE['run_6']['end']\n",
    "final_end_candidate = final_start_candidate + baseline_dur\n",
    "\n",
    "k5_max_time = float(pd.to_numeric(k5_data[\"time_sec\"], errors=\"coerce\").max())\n",
    "nirs_max_time = float(pd.to_numeric(nirs_data[\"time_sec\"], errors=\"coerce\").max())\n",
    "\n",
    "if final_end_candidate <= min(k5_max_time, nirs_max_time):\n",
    "    k5_final = _extract_window(k5_data, final_start_candidate, final_end_candidate)\n",
    "    nirs_final = _extract_window(nirs_data, final_start_candidate, final_end_candidate)\n",
    "else:\n",
    "    # Fallback to last 5 minutes when explicit final baseline is not fully recorded.\n",
    "    k5_final = _extract_window(k5_data, max(0, k5_max_time - baseline_dur), k5_max_time + 1e-9)\n",
    "    nirs_final = _extract_window(nirs_data, max(0, nirs_max_time - baseline_dur), nirs_max_time + 1e-9)\n",
    "\n",
    "baseline_initial = {\n",
    "    \"VO2\": pd.to_numeric(k5_initial[vo2_col_k5], errors=\"coerce\").mean(),\n",
    "    \"TSI\": pd.to_numeric(nirs_initial[tsi_col_nirs], errors=\"coerce\").mean(),\n",
    "    \"HHb\": pd.to_numeric(nirs_initial[hhb_col_nirs], errors=\"coerce\").mean() if hhb_col_nirs else np.nan,\n",
    "}\n",
    "baseline_final = {\n",
    "    \"VO2\": pd.to_numeric(k5_final[vo2_col_k5], errors=\"coerce\").mean(),\n",
    "    \"TSI\": pd.to_numeric(nirs_final[tsi_col_nirs], errors=\"coerce\").mean(),\n",
    "    \"HHb\": pd.to_numeric(nirs_final[hhb_col_nirs], errors=\"coerce\").mean() if hhb_col_nirs else np.nan,\n",
    "}\n",
    "\n",
    "baseline_comparison_df = compare_baselines(baseline_initial, baseline_final)\n",
    "print(\"Baseline comparison (initial vs final):\")\n",
    "display(baseline_comparison_df)\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# Repeated-measures ANOVA + post-hoc (Bonferroni) + effect sizes\n",
    "# ---------------------------------------------------------------------------\n",
    "repeat_rows = []\n",
    "for cond, blocks in CONDITION_MAP.items():\n",
    "    for rep_id, blk in enumerate(blocks, start=1):\n",
    "        row = block_metrics_df.loc[block_metrics_df[\"block\"] == blk]\n",
    "        if len(row) == 0:\n",
    "            continue\n",
    "        repeat_rows.append(\n",
    "            {\n",
    "                \"subject\": f\"repeat_{rep_id}\",\n",
    "                \"condition\": cond,\n",
    "                \"VO2_mean\": row[\"VO2_mean\"].iloc[0],\n",
    "                \"TSI_mean\": row[\"TSI_mean\"].iloc[0],\n",
    "                \"HHb_mean\": row[\"HHb_mean\"].iloc[0],\n",
    "                \"VO2_auc\": row[\"VO2_auc\"].iloc[0],\n",
    "                \"TSI_slope\": row[\"TSI_slope\"].iloc[0],\n",
    "                \"HHb_slope\": row[\"HHb_slope\"].iloc[0],\n",
    "            }\n",
    "        )\n",
    "\n",
    "anova_input_df = pd.DataFrame(repeat_rows)\n",
    "anova_targets = [\"VO2_mean\", \"VO2_auc\", \"TSI_slope\", \"HHb_slope\"]\n",
    "anova_tables = {}\n",
    "posthoc_rows = []\n",
    "\n",
    "for target in anova_targets:\n",
    "    target_df = anova_input_df[[\"subject\", \"condition\", target]].dropna().rename(columns={target: \"value\"})\n",
    "\n",
    "    if target_df[\"subject\"].nunique() >= 2 and target_df[\"condition\"].nunique() == 3:\n",
    "        model = AnovaRM(target_df, depvar=\"value\", subject=\"subject\", within=[\"condition\"]).fit()\n",
    "        tbl = model.anova_table.copy()\n",
    "        f_val = float(tbl[\"F Value\"].iloc[0])\n",
    "        df_num = float(tbl[\"Num DF\"].iloc[0])\n",
    "        df_den = float(tbl[\"Den DF\"].iloc[0])\n",
    "        eta_sq = (f_val * df_num) / ((f_val * df_num) + df_den)\n",
    "\n",
    "        tbl = tbl.reset_index().rename(columns={\"index\": \"Effect\"})\n",
    "        tbl[\"Variable\"] = target\n",
    "        tbl[\"eta_squared\"] = eta_sq\n",
    "        anova_tables[target] = tbl\n",
    "\n",
    "        wide = target_df.pivot(index=\"subject\", columns=\"condition\", values=\"value\")\n",
    "        pairs = [(\"A\", \"B\"), (\"A\", \"C\"), (\"B\", \"C\")]\n",
    "        raw_ps = []\n",
    "        pair_stats = []\n",
    "\n",
    "        for a, b in pairs:\n",
    "            pair_data = wide[[a, b]].dropna()\n",
    "            if len(pair_data) >= 2:\n",
    "                t_stat, p_val = stats.ttest_rel(pair_data[a], pair_data[b])\n",
    "                diff = pair_data[a] - pair_data[b]\n",
    "                if diff.std(ddof=1) > 0:\n",
    "                    cohen_d = diff.mean() / diff.std(ddof=1)\n",
    "                else:\n",
    "                    cohen_d = np.nan\n",
    "            else:\n",
    "                t_stat, p_val, cohen_d = np.nan, np.nan, np.nan\n",
    "\n",
    "            raw_ps.append(p_val)\n",
    "            pair_stats.append((a, b, t_stat, p_val, cohen_d, len(pair_data)))\n",
    "\n",
    "        bonf_ps = [min(p * 3, 1.0) if pd.notna(p) else np.nan for p in raw_ps]\n",
    "        for (a, b, t_stat, p_val, cohen_d, n), p_bonf in zip(pair_stats, bonf_ps):\n",
    "            posthoc_rows.append(\n",
    "                {\n",
    "                    \"Variable\": target,\n",
    "                    \"Comparison\": f\"{a} vs {b}\",\n",
    "                    \"t_stat\": t_stat,\n",
    "                    \"p_raw\": p_val,\n",
    "                    \"p_bonferroni\": p_bonf,\n",
    "                    \"cohens_d\": cohen_d,\n",
    "                    \"n_pairs\": n,\n",
    "                }\n",
    "            )\n",
    "\n",
    "anova_results_df = pd.concat(anova_tables.values(), ignore_index=True) if len(anova_tables) > 0 else pd.DataFrame()\n",
    "posthoc_results_df = pd.DataFrame(posthoc_rows)\n",
    "\n",
    "print(\"Repeated-measures ANOVA:\")\n",
    "display(anova_results_df)\n",
    "print(\"Post-hoc pairwise tests (Bonferroni):\")\n",
    "display(posthoc_results_df)\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# Correlation analysis\n",
    "# ---------------------------------------------------------------------------\n",
    "corr_cols = [\"VO2_mean\", \"TSI_mean\", \"HHb_mean\", \"Force_mean\"]\n",
    "corr_input_df = block_metrics_df[corr_cols].copy()\n",
    "\n",
    "corr_pairs = [(\"VO2_mean\", \"TSI_mean\"), (\"VO2_mean\", \"HHb_mean\"), (\"TSI_mean\", \"Force_mean\")]\n",
    "corr_rows = []\n",
    "for x_col, y_col in corr_pairs:\n",
    "    pair_df = corr_input_df[[x_col, y_col]].dropna()\n",
    "    if len(pair_df) >= 3:\n",
    "        r, p = stats.pearsonr(pair_df[x_col], pair_df[y_col])\n",
    "    else:\n",
    "        r, p = np.nan, np.nan\n",
    "    corr_rows.append({\"X\": x_col, \"Y\": y_col, \"pearson_r\": r, \"p_value\": p, \"n\": len(pair_df)})\n",
    "\n",
    "correlation_results_df = pd.DataFrame(corr_rows)\n",
    "correlation_matrix_df = corr_input_df.corr(method=\"pearson\")\n",
    "\n",
    "print(\"Pearson correlations:\")\n",
    "display(correlation_results_df)\n",
    "print(\"Correlation matrix:\")\n",
    "display(correlation_matrix_df)\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# Visualizations (display only, no file write)\n",
    "# ---------------------------------------------------------------------------\n",
    "sns.set(style=\"whitegrid\", context=\"talk\")\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "plot_specs = [\n",
    "    (\"VO2_mean\", \"VO2 by condition\"),\n",
    "    (\"TSI_mean\", \"TSI by condition\"),\n",
    "    (\"HHb_mean\", \"HHb by condition\"),\n",
    "]\n",
    "for ax, (col, title) in zip(axes, plot_specs):\n",
    "    sns.boxplot(data=block_metrics_df, x=\"condition\", y=col, ax=ax)\n",
    "    sns.stripplot(data=block_metrics_df, x=\"condition\", y=col, color=\"black\", alpha=0.6, ax=ax)\n",
    "    ax.set_title(title)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "auc_stats = block_metrics_df.groupby(\"condition\")[\"VO2_auc\"].agg([\"mean\", \"std\"]).reset_index()\n",
    "ax.bar(auc_stats[\"condition\"], auc_stats[\"mean\"], yerr=auc_stats[\"std\"], capsize=5)\n",
    "ax.set_title(\"VO2 AUC by condition\")\n",
    "ax.set_ylabel(\"AUC\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "for ax, col, title in [\n",
    "    (axes[0], \"TSI_slope\", \"TSI oxygenation slope\"),\n",
    "    (axes[1], \"HHb_slope\", \"HHb deoxygenation slope\"),\n",
    "]:\n",
    "    tmp = block_metrics_df.groupby(\"condition\")[col].agg([\"mean\", \"std\"]).reset_index()\n",
    "    ax.bar(tmp[\"condition\"], tmp[\"mean\"], yerr=tmp[\"std\"], capsize=5)\n",
    "    ax.set_title(title)\n",
    "    ax.set_ylabel(\"Slope\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Baseline comparison: split panels to avoid VO2 masking TSI/HHb scales.\n",
    "fig, axes = plt.subplots(1, 3, figsize=(14, 4))\n",
    "for i, metric in enumerate([\"VO2\", \"TSI\", \"HHb\"]):\n",
    "    sub = baseline_comparison_df[baseline_comparison_df[\"Metric\"] == metric].iloc[0]\n",
    "    axes[i].bar([\"Initial\", \"Final\"], [sub[\"Baseline_Initial\"], sub[\"Baseline_Final\"]])\n",
    "    axes[i].set_title(f\"{metric}: initial vs final\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "sns.heatmap(correlation_matrix_df, annot=True, fmt=\".2f\", cmap=\"coolwarm\", center=0, ax=ax)\n",
    "ax.set_title(\"Correlation heatmap (block level)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"Advanced notebook-core pipeline complete.\")"
   ]
  },
