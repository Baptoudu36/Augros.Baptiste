     "text": [
      "✓ DEPOXY protocol and segmentation functions defined\n"
     ]
    }
   ],
   "source": [
    "# ============================================================================\n",
    "# DATA SEGMENTATION FUNCTIONS FOR DEPOXY PROTOCOL\n",
    "# ============================================================================\n",
    "\n",
    "def segment_data_by_phase(df, timeline, time_col='time_sec'):\n",
    "    \"\"\"\n",
    "    Segment data according to protocol phases.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : DataFrame\n",
    "        Data with time column\n",
    "    timeline : dict\n",
    "        Protocol timeline from create_protocol_timeline()\n",
    "    time_col : str\n",
    "        Name of time column\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    dict : Dictionary with DataFrames for each phase\n",
    "    \"\"\"\n",
    "    segments = {}\n",
    "    \n",
    "    for phase_name, phase_info in timeline.items():\n",
    "        mask = (df[time_col] >= phase_info['start']) & (df[time_col] < phase_info['end'])\n",
    "        segment_data = df[mask].copy()\n",
    "        \n",
    "        if len(segment_data) > 0:\n",
    "            segments[phase_name] = {\n",
    "                'data': segment_data,\n",
    "                'info': phase_info,\n",
    "                'n_samples': len(segment_data),\n",
    "                'duration': phase_info['end'] - phase_info['start']\n",
    "            }\n",
    "    \n",
    "    return segments\n",
    "\n",
    "\n",
    "def extract_steady_state_from_block(df, start_time, duration=300, \n",
    "                                   steady_start_offset=120, steady_end_offset=270,\n",
    "                                   time_col='time_sec'):\n",
    "    \"\"\"\n",
    "    Extract steady-state period from a running block.\n",
    "    Avoids first 2 minutes (adaptation) and last 30 seconds (anticipation).\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : DataFrame\n",
    "        Complete dataset\n",
    "    start_time : float\n",
    "        Start time of running block (seconds)\n",
    "    duration : float\n",
    "        Total duration of running block (seconds)\n",
    "    steady_start_offset : float\n",
    "        Offset from block start to begin steady-state (default 120s = 2 min)\n",
    "    steady_end_offset : float\n",
    "        Offset from block start to end steady-state (default 270s = 4.5 min)\n",
    "    time_col : str\n",
    "        Name of time column\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    DataFrame : Steady-state data\n",
    "    dict : Information about the extraction\n",
    "    \"\"\"\n",
    "    steady_start = start_time + steady_start_offset\n",
    "    steady_end = start_time + steady_end_offset\n",
    "    \n",
    "    mask = (df[time_col] >= steady_start) & (df[time_col] < steady_end)\n",
    "    steady_data = df[mask].copy()\n",
    "    \n",
    "    info = {\n",
    "        'start_time': steady_start,\n",
    "        'end_time': steady_end,\n",
    "        'duration': steady_end - steady_start,\n",
    "        'n_samples': len(steady_data)\n",
    "    }\n",
    "    \n",
    "    return steady_data, info\n",
    "\n",
    "\n",
    "def analyze_by_shoe_condition(segments_dict, timeline, columns_to_analyze):\n",
    "    \"\"\"\n",
    "    Aggregate data by shoe condition (A, B, C).\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    segments_dict : dict\n",
    "        Dictionary of segmented data (from segment_data_by_phase)\n",
    "    timeline : dict\n",
    "        Protocol timeline\n",
    "    columns_to_analyze : list\n",
    "        List of column names to compute statistics for\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    DataFrame : Summary statistics by shoe condition\n",
    "    \"\"\"\n",
    "    results = []\n",
    "    \n",
    "    # Process each running block\n",
    "    for block in range(1, PROTOCOL['n_blocks'] + 1):\n",
    "        run_key = f'run_{block}'\n",
    "        \n",
    "        if run_key in segments_dict:\n",
    "            segment = segments_dict[run_key]\n",
    "            run_data = segment['data']\n",
    "            \n",
    "            # Get shoe condition info\n",
    "            shoe_code = timeline[run_key]['shoe_code']\n",
    "            shoe_name = timeline[run_key]['shoe_name']\n",
    "            \n",
    "            # Compute statistics for each column\n",
    "            block_stats = {\n",
    "                'block': block,\n",
    "                'shoe_code': shoe_code,\n",
    "                'shoe_name': shoe_name,\n",
    "                'n_samples': len(run_data)\n",
    "            }\n",
    "            \n",
    "            for col in columns_to_analyze:\n",
    "                if col in run_data.columns:\n",
    "                    data = run_data[col].dropna()\n",
    "                    if len(data) > 0:\n",
    "                        block_stats[f'{col}_mean'] = data.mean()\n",
    "                        block_stats[f'{col}_std'] = data.std()\n",
    "                        block_stats[f'{col}_min'] = data.min()\n",
    "                        block_stats[f'{col}_max'] = data.max()\n",
    "            \n",
    "            results.append(block_stats)\n",
    "    \n",
    "    return pd.DataFrame(results)\n",
    "\n",
    "\n",
    "def aggregate_by_shoe_type(block_df):\n",
    "    \"\"\"\n",
    "    Aggregate block-level results by shoe type (A, B, C).\n",
    "    Computes mean across repeated conditions.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    block_df : DataFrame\n",
    "        Results from analyze_by_shoe_condition()\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    DataFrame : Aggregated statistics by shoe type\n",
    "    \"\"\"\n",
    "    # Group by shoe_code and compute mean/std across blocks\n",
    "    numeric_cols = block_df.select_dtypes(include=[np.number]).columns\n",
    "    numeric_cols = [col for col in numeric_cols if col != 'block']\n",
    "    \n",
    "    agg_dict = {col: ['mean', 'std'] for col in numeric_cols}\n",
    "    agg_dict['shoe_name'] = 'first'\n",
    "    agg_dict['block'] = 'count'\n",
    "    \n",
    "    shoe_summary = block_df.groupby('shoe_code').agg(agg_dict).reset_index()\n",
    "    shoe_summary.columns = ['_'.join(col).strip('_') for col in shoe_summary.columns.values]\n",
    "    shoe_summary = shoe_summary.rename(columns={'block_count': 'n_blocks'})\n",
    "    \n",
    "    return shoe_summary\n",
    "\n",
    "\n",
    "print(\"✓ DEPOXY protocol and segmentation functions defined\")\n"
   ]
