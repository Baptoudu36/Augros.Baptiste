    "# ============================================================================\n",
    "# DEPOXY PROTOCOL DEFINITION\n",
    "# ============================================================================\n",
    "\n",
    "# Protocol timing (in seconds)\n",
    "PROTOCOL = {\n",
    "    'baseline_duration': 300,  # 5 minutes baseline\n",
    "    'run_duration': 300,       # 5 minutes per running block\n",
    "    'recovery_duration': 300,  # 5 minutes per recovery block\n",
    "    'n_blocks': 6              # Total number of running blocks\n",
    "}\n",
    "\n",
    "# Shoe conditions (ABCCBA design)\n",
    "SHOE_CONDITIONS = {\n",
    "    1: {'code': 'A', 'name': 'KipRun KipStorm Foam', 'color': '#FF6B6B'},\n",
    "    2: {'code': 'B', 'name': 'KipRun KipStorm Carbon', 'color': '#4ECDC4'},\n",
    "    3: {'code': 'C', 'name': 'Prototype', 'color': '#95E1D3'},\n",
    "    4: {'code': 'C', 'name': 'Prototype', 'color': '#95E1D3'},\n",
    "    5: {'code': 'B', 'name': 'KipRun KipStorm Carbon', 'color': '#4ECDC4'},\n",
    "    6: {'code': 'A', 'name': 'KipRun KipStorm Foam', 'color': '#FF6B6B'}\n",
    "}\n",
    "\n",
    "# Calculate time windows for each phase\n",
    "def create_protocol_timeline():\n",
    "    \"\"\"\n",
    "    Create timeline with start/end times for all protocol phases.\n",
    "    Returns a dictionary with timing for baseline, runs, and recoveries.\n",
    "    \"\"\"\n",
    "    timeline = {}\n",
    "    current_time = 0\n",
    "    \n",
    "    # Baseline\n",
    "    timeline['baseline'] = {\n",
    "        'start': current_time,\n",
    "        'end': current_time + PROTOCOL['baseline_duration'],\n",
    "        'phase': 'Baseline'\n",
    "    }\n",
    "    current_time += PROTOCOL['baseline_duration']\n",
    "    \n",
    "    # Running blocks with recovery only between blocks\n",
    "    for block in range(1, PROTOCOL['n_blocks'] + 1):\n",
    "        # Running block\n",
    "        timeline[f'run_{block}'] = {\n",
    "            'start': current_time,\n",
    "            'end': current_time + PROTOCOL['run_duration'],\n",
    "            'phase': 'Running',\n",
    "            'block': block,\n",
    "            'shoe_code': SHOE_CONDITIONS[block]['code'],\n",
    "            'shoe_name': SHOE_CONDITIONS[block]['name'],\n",
    "            'color': SHOE_CONDITIONS[block]['color']\n",
    "        }\n",
    "        current_time += PROTOCOL['run_duration']\n",
    "        \n",
    "        # Recovery block only if another run follows\n",
    "        if block < PROTOCOL['n_blocks']:\n",
    "            timeline[f'recovery_{block}'] = {\n",
    "                'start': current_time,\n",
    "                'end': current_time + PROTOCOL['recovery_duration'],\n",
    "                'phase': 'Recovery',\n",
    "                'block': block\n",
    "            }\n",
    "            current_time += PROTOCOL['recovery_duration']\n",
    "\n",
    "    # Final baseline (5 minutes) after the 6th running block\n",
    "    timeline['final_baseline'] = {\n",
    "        'start': current_time,\n",
    "        'end': current_time + PROTOCOL['baseline_duration'],\n",
    "        'phase': 'Final Baseline'\n",
    "    }\n",
    "    current_time += PROTOCOL['baseline_duration']\n",
    "    \n",
    "    return timeline\n",
    "\n",
    "# Create the timeline\n",
    "TIMELINE = create_protocol_timeline()\n",
    "\n",
    "# Print protocol summary\n",
    "print(\"=\"*80)\n",
    "print(\"DEPOXY PROTOCOL CONFIGURATION\")\n",
    "print(\"=\"*80)\n",
    "print(f\"\\nBaseline duration: {PROTOCOL['baseline_duration']/60:.1f} min\")\n",
    "print(f\"Running block duration: {PROTOCOL['run_duration']/60:.1f} min\")\n",
    "print(f\"Recovery duration: {PROTOCOL['recovery_duration']/60:.1f} min\")\n",
    "print(f\"Number of running blocks: {PROTOCOL['n_blocks']}\")\n",
    "print(f\"Number of recovery blocks: {PROTOCOL['n_blocks'] - 1}\")\n",
    "print(f\"Final baseline duration: {PROTOCOL['baseline_duration']/60:.1f} min\")\n",
    "total_protocol_end = TIMELINE['final_baseline']['end']\n",
    "print(f\"\\nTotal protocol duration: {total_protocol_end/60:.1f} min\")\n",
    "print(\"\\n--- SHOE SEQUENCE (ABCCBA) ---\")\n",
    "for block in range(1, PROTOCOL['n_blocks'] + 1):\n",
    "    info = SHOE_CONDITIONS[block]\n",
    "    run_info = TIMELINE[f'run_{block}']\n",
    "    print(f\"Block {block}: {info['code']} - {info['name']:<30} \"\n",
    "          f\"({run_info['start']/60:>5.1f} - {run_info['end']/60:>5.1f} min)\")\n",
    "print(\"=\"*80)\n"
   ]
