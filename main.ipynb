    "\n",
    "    sync_payload = synchronize_signals(k5_data_raw, nirs_data_raw, fp_data_raw)\n",
    "\n",
    "    k5_sync = sync_payload[\"cosmed\"].copy()\n",
    "    nirs_sync = sync_payload[\"nirs\"].copy()\n",
    "    fp_sync = sync_payload[\"forces\"].copy()\n",
    "    sync_meta = sync_payload.get(\"metadata\", {})\n",
    "    target_fs = sync_meta.get(\"sampling_rate_hz\", None)\n",
    "\n",
    "    # Filter only continuous physiological/mechanical channels.\n",
    "    k5_filter_cols = [\n",
    "        c for c in [\"VO2_ml_min\", \"VCO2_ml_min\", \"RER\", \"VE_L_min\", \"Freq_Resp\", \"VT_L\", \"HR_bpm\"]\n",
    "        if c in k5_sync.columns\n",
    "    ]\n",
    "    nirs_filter_cols = [\n",
    "        c for c in [\"SmO2_Quad\", \"SmO2_Calf\", \"HHb_Quad\", \"HHb_Calf\", \"tHb_Quad\", \"tHb_Calf\", \"HbDiff_Quad\", \"HbDiff_Calf\"]\n",
    "        if c in nirs_sync.columns\n",
    "    ]\n",
    "    fp_filter_cols = [\n",
    "        c for c in [\"sensor1_N\", \"sensor2_N\", \"sensor3_N\", \"sensor4_N\", \"total_force_N\"]\n",
    "        if c in fp_sync.columns\n",
    "    ]\n",
    "\n",
    "    if isinstance(target_fs, (int, float)) and target_fs > 0:\n",
    "        for col in k5_filter_cols:\n",
    "            k5_sync[col] = lowpass_filter(\n",
    "                k5_sync[col].values,\n",
    "                cutoff=CONFIG[\"filter_cutoff\"],\n",
    "                fs=target_fs,\n",
    "                order=4,\n",
    "            )\n",
    "\n",
    "        for col in nirs_filter_cols:\n",
    "            nirs_sync[col] = lowpass_filter(\n",
    "                nirs_sync[col].values,\n",
    "                cutoff=CONFIG[\"filter_cutoff\"],\n",
    "                fs=target_fs,\n",
    "                order=4,\n",
    "            )\n",
    "\n",
    "        for col in fp_filter_cols:\n",
    "            fp_sync[col] = lowpass_filter(\n",
    "                fp_sync[col].values,\n",
    "                cutoff=CONFIG[\"filter_cutoff\"],\n",
    "                fs=target_fs,\n",
    "                order=4,\n",
    "            )\n",
