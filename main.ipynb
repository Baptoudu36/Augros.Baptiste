   "source": [
    "# ============================================================================\n",
    "# CONSOLIDATION BY SHOE CONDITION (STEADY-STATE BLOCKS)\n",
    "# ============================================================================\n",
    "\n",
    "required_vars = [\n",
    "    'k5_data', 'hr_data', 'nirs_data', 'fp_data',\n",
    "    'TIMELINE', 'PROTOCOL',\n",
    "    'extract_steady_state_from_block', 'detect_force_peaks'\n",
    "]\n",
    "missing_vars = [name for name in required_vars if name not in globals()]\n",
    "if missing_vars:\n",
    "    raise RuntimeError(\n",
    "        \"Missing variables. Run the data loading and protocol cells first: \"\n",
    "        + \", \".join(missing_vars)\n",
    "    )\n",
    "\n",
    "\n",
    "def _estimate_sampling_rate(time_sec):\n",
    "    if len(time_sec) < 3:\n",
    "        return np.nan\n",
    "    diffs = np.diff(time_sec)\n",
    "    diffs = diffs[diffs > 0]\n",
    "    if len(diffs) == 0:\n",
    "        return np.nan\n",
    "    return 1.0 / np.median(diffs)\n",
    "\n",
    "\n",
    "def build_block_level_summary(k5_df, hr_df, nirs_df, fp_df, timeline):\n",
    "    \"\"\"\n",
    "    Build block-level steady-state summaries for each running block.\n",
    "    Returns a DataFrame with one row per block (A, B, C, C, B, A).\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "\n",
    "    for block in range(1, PROTOCOL['n_blocks'] + 1):\n",
    "        run_key = f\"run_{block}\"\n",
    "        if run_key not in timeline:\n",
    "            continue\n",
    "        info = timeline[run_key]\n",
    "        start_time = info['start']\n",
    "\n",
    "        # Extract steady-state windows for each modality\n",
    "        k5_ss, _ = extract_steady_state_from_block(k5_df, start_time)\n",
    "        hr_ss, _ = extract_steady_state_from_block(hr_df, start_time)\n",
    "        nirs_ss, _ = extract_steady_state_from_block(nirs_df, start_time)\n",
    "        fp_ss, _ = extract_steady_state_from_block(fp_df, start_time)\n",
    "\n",
    "        # Means for variables of interest\n",
    "        def _safe_mean(df, col):\n",
    "            if df is None or col not in df.columns:\n",
    "                return np.nan\n",
    "            return df[col].dropna().mean()\n",
    "\n",
    "        vo2_mean = _safe_mean(k5_ss, 'VO2_ml_min')\n",
    "        hr_mean = _safe_mean(hr_ss, 'HR_bpm')\n",
    "        smo2_quad = _safe_mean(nirs_ss, 'SmO2_Quad')\n",
    "        smo2_calf = _safe_mean(nirs_ss, 'SmO2_Calf')\n",
    "\n",
    "        # Mean peak force from force plate steady-state\n",
    "        mean_peak_force = np.nan\n",
    "        if fp_ss is not None and len(fp_ss) > 10 and 'total_force_N' in fp_ss.columns:\n",
    "            sr = _estimate_sampling_rate(fp_ss['time_sec'].values)\n",
    "            distance_samples = int(sr * 0.4) if not np.isnan(sr) else 100\n",
    "            distance_samples = max(distance_samples, 20)\n",
    "            peak_result = detect_force_peaks(\n",
    "                fp_ss,\n",
    "                time_col='time_sec',\n",
    "                force_col='total_force_N',\n",
    "                height_threshold=None,\n",
    "                distance_samples=distance_samples\n",
    "            )\n",
    "            mean_peak_force = peak_result.get('mean_peak_force', np.nan)\n",
    "\n",
    "        rows.append({\n",
    "            'block': block,\n",
    "            'shoe_code': info['shoe_code'],\n",
    "            'shoe_name': info['shoe_name'],\n",
    "            'VO2_ml_min': vo2_mean,\n",
    "            'HR_bpm': hr_mean,\n",
    "            'SmO2_Quad': smo2_quad,\n",
    "            'SmO2_Calf': smo2_calf,\n",
    "            'Mean_Peak_Force': mean_peak_force\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "\n",
    "block_level_df = build_block_level_summary(\n",
    "    k5_df=k5_data,\n",
    "    hr_df=hr_data,\n",
    "    nirs_df=nirs_data,\n",
    "    fp_df=fp_data,\n",
    "    timeline=TIMELINE\n",
    ")\n",
    "\n",
    "print(\"Block-level steady-state summary (per trial):\")\n",
    "display(block_level_df)\n",
    "\n",
    "# Consolidate by shoe condition (mean of two trials per shoe)\n",
    "consolidated_df = (\n",
    "    block_level_df\n",
    "    .groupby(['shoe_code', 'shoe_name'], as_index=False)\n",
    "    .mean(numeric_only=True)\n",
    "    .sort_values('shoe_code')\n",
    ")\n",
    "\n",
    "# Final formatted table for statistical analysis\n",
    "analysis_df = consolidated_df[\n",
    "    ['shoe_code', 'shoe_name', 'VO2_ml_min', 'HR_bpm',\n",
    "     'SmO2_Quad', 'SmO2_Calf', 'Mean_Peak_Force']\n",
    "].copy()\n",
    "\n",
    "analysis_df = analysis_df.rename(columns={\n",
    "    'shoe_code': 'Condition',\n",
    "    'shoe_name': 'Shoe',\n",
    "    'VO2_ml_min': 'VO2',\n",
    "    'HR_bpm': 'HR',\n",
    "    'SmO2_Quad': 'SmO2_Quad',\n",
    "    'SmO2_Calf': 'SmO2_Calf',\n",
    "    'Mean_Peak_Force': 'Mean_Peak_Force'\n",
    "})\n",
    "\n",
    "print(\"Consolidated table (mean of two trials per shoe):\")\n",
    "display(analysis_df)\n"
   ]
  },
