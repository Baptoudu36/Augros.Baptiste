    "\n",
    "def plot_force_sensors(fp_data, baseline_info, steady_info, \n",
    "                       time_col='time_sec', figsize=(16, 10)):\n",
    "    \"\"\"\n",
    "    Visualize the 4 force sensors individually over time.\n",
    "    \"\"\"\n",
    "    fig, axes = plt.subplots(5, 1, figsize=figsize, sharex=True)\n",
    "    fig.suptitle('Individual Force Sensors and Total Force', \n",
    "                fontsize=16, fontweight='bold')\n",
    "    \n",
    "    # Helper function to mark windows\n",
    "    def mark_windows(ax):\n",
    "        if baseline_info:\n",
    "            ax.axvspan(baseline_info['start_time']/60, baseline_info['end_time']/60, \n",
    "                      alpha=0.2, color='blue', label='Baseline')\n",
    "        if steady_info:\n",
    "            ax.axvspan(steady_info['start_time']/60, steady_info['end_time']/60, \n",
    "                      alpha=0.2, color='green', label='Steady-State')\n",
    "    \n",
    "    sample_rate = 5  # Downsample for visualization\n",
    "    time_min = fp_data[time_col][::sample_rate] / 60\n",
    "    \n",
    "    # Sensor 1\n",
    "    ax = axes[0]\n",
    "    if 'sensor1_N' in fp_data.columns:\n",
    "        ax.plot(time_min, fp_data['sensor1_N'][::sample_rate], \n",
    "               'royalblue', linewidth=0.8, alpha=0.8)\n",
    "        mark_windows(ax)\n",
    "        ax.set_ylabel('Force (N)', fontweight='bold')\n",
    "        ax.set_title('Sensor 1', fontweight='bold', fontsize=12)\n",
    "        ax.grid(True, alpha=0.3)\n",
    "        ax.legend(loc='upper right', fontsize=7)\n",
    "    \n",
    "    # Sensor 2\n",
    "    ax = axes[1]\n",
    "    if 'sensor2_N' in fp_data.columns:\n",
    "        ax.plot(time_min, fp_data['sensor2_N'][::sample_rate], \n",
    "               'forestgreen', linewidth=0.8, alpha=0.8)\n",
    "        mark_windows(ax)\n",
    "        ax.set_ylabel('Force (N)', fontweight='bold')\n",
    "        ax.set_title('Sensor 2', fontweight='bold', fontsize=12)\n",
    "        ax.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Sensor 3\n",
    "    ax = axes[2]\n",
    "    if 'sensor3_N' in fp_data.columns:\n",
    "        ax.plot(time_min, fp_data['sensor3_N'][::sample_rate], \n",
    "               'darkorange', linewidth=0.8, alpha=0.8)\n",
    "        mark_windows(ax)\n",
    "        ax.set_ylabel('Force (N)', fontweight='bold')\n",
    "        ax.set_title('Sensor 3', fontweight='bold', fontsize=12)\n",
    "        ax.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Sensor 4\n",
    "    ax = axes[3]\n",
    "    if 'sensor4_N' in fp_data.columns:\n",
    "        ax.plot(time_min, fp_data['sensor4_N'][::sample_rate], \n",
    "               'crimson', linewidth=0.8, alpha=0.8)\n",
    "        mark_windows(ax)\n",
    "        ax.set_ylabel('Force (N)', fontweight='bold')\n",
    "        ax.set_title('Sensor 4', fontweight='bold', fontsize=12)\n",
    "        ax.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Total Force\n",
    "    ax = axes[4]\n",
    "    if 'total_force_N' in fp_data.columns:\n",
    "        ax.plot(time_min, fp_data['total_force_N'][::sample_rate], \n",
    "               'darkblue', linewidth=1.2, alpha=0.9)\n",
    "        mark_windows(ax)\n",
    "        ax.set_ylabel('Force (N)', fontweight='bold')\n",
    "        ax.set_title('Total Force (Sum of 4 Sensors)', fontweight='bold', fontsize=12)\n",
    "        ax.set_xlabel('Time (min)', fontweight='bold')\n",
    "        ax.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    return fig\n",
    "\n",
    "\n",
    "def plot_force_peaks(fp_data, peak_result, baseline_info, steady_info, \n",
    "                    time_col='time_sec', force_col='total_force_N',\n",
    "                    figsize=(14, 5)):\n",
    "    \"\"\"\n",
    "    Visualize detected force peaks.\n",
    "    \"\"\"\n",
    "    fig, axes = plt.subplots(1, 2, figsize=figsize)\n",
    "    \n",
    "    # Plot 1: Overview with peaks\n",
    "    ax = axes[0]\n",
    "    # Downsample for visualization\n",
    "    sample_rate = 10\n",
    "    ax.plot(fp_data[time_col][::sample_rate]/60, \n",
    "           fp_data[force_col][::sample_rate],\n",
    "           'b-', linewidth=0.5, alpha=0.7, label='Force')\n",
    "    \n",
    "    if len(peak_result['peak_times']) > 0:\n",
    "        ax.plot(peak_result['peak_times']/60, peak_result['peak_values'],\n",
    "               'ro', markersize=3, label=f'Peaks (N={peak_result[\"n_peaks\"]})')\n",
    "    \n",
    "    # Mark windows\n",
    "    if baseline_info:\n",
    "        ax.axvspan(baseline_info['start_time']/60, baseline_info['end_time']/60,\n",
    "                  alpha=0.2, color='blue', label='Baseline')\n",
    "    if steady_info:\n",
    "        ax.axvspan(steady_info['start_time']/60, steady_info['end_time']/60,\n",
    "                  alpha=0.2, color='green', label='Steady-State')\n",
    "    \n",
    "    ax.set_xlabel('Time (min)', fontweight='bold')\n",
    "    ax.set_ylabel('Force (N)', fontweight='bold')\n",
    "    ax.set_title('Force Peak Detection', fontweight='bold')\n",
    "    ax.legend(fontsize=8)\n",
    "    ax.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Plot 2: Zoom on steady-state window\n",
    "    ax = axes[1]\n",
    "    if steady_info:\n",
    "        mask = ((fp_data[time_col] >= steady_info['start_time']) & \n",
    "               (fp_data[time_col] <= steady_info['end_time']))\n",
    "        steady_fp = fp_data[mask]\n",
    "        \n",
    "        ax.plot(steady_fp[time_col]/60, steady_fp[force_col],\n",
    "               'b-', linewidth=0.8, alpha=0.7)\n",
    "        \n",
    "        # Peaks in steady-state window\n",
    "        if len(peak_result['peak_times']) > 0:\n",
    "            peak_times_array = np.array(peak_result['peak_times'])\n",
    "            peak_values_array = np.array(peak_result['peak_values'])\n",
    "            steady_peaks_mask = ((peak_times_array >= steady_info['start_time']) &\n",
    "                                (peak_times_array <= steady_info['end_time']))\n",
    "            if np.any(steady_peaks_mask):\n",
    "                ax.plot(peak_times_array[steady_peaks_mask]/60,\n",
    "                       peak_values_array[steady_peaks_mask],\n",
    "                       'ro', markersize=5)\n",
    "        \n",
    "        ax.set_xlabel('Time (min)', fontweight='bold')\n",
    "        ax.set_ylabel('Force (N)', fontweight='bold')\n",
    "        ax.set_title('Zoom: Steady-State Window', fontweight='bold')\n",
    "        ax.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    return fig\n",
    "\n",
    "\n",
    "print(\"✓ Visualization functions defined\")\n"
   ]
