   ],
   "source": [
    "# ============================================================================\n",
    "# SECTION 2-7: ADVANCED ANALYSIS UTILITIES\n",
    "# ============================================================================\n",
    "\n",
    "\n",
    "def _get_time_column(df):\n",
    "    \"\"\"Return the most likely time column name for a dataframe.\"\"\"\n",
    "    candidates = [\"time_sec\", \"time_s\", \"time\", \"Time\", \"timestamp\", \"Timestamp\"]\n",
    "    for col in candidates:\n",
    "        if col in df.columns:\n",
    "            return col\n",
    "    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "    return numeric_cols[0] if numeric_cols else None\n",
    "\n",
    "\n",
    "def _detect_trigger_time(df):\n",
    "    \"\"\"Detect first trigger timestamp from common trigger/event columns.\"\"\"\n",
    "    trigger_cols = [\n",
    "        col\n",
    "        for col in df.columns\n",
    "        if any(tag in col.lower() for tag in [\"trigger\", \"event\", \"marker\", \"sync\"])\n",
    "    ]\n",
    "    if not trigger_cols:\n",
    "        return None\n",
    "\n",
    "    time_col = _get_time_column(df)\n",
    "    if time_col is None:\n",
    "        return None\n",
    "\n",
    "    for col in trigger_cols:\n",
    "        values = pd.to_numeric(df[col], errors=\"coerce\")\n",
    "        idx = values[values > 0].index\n",
    "        if len(idx) > 0:\n",
    "            return float(pd.to_numeric(df.loc[idx[0], time_col], errors=\"coerce\"))\n",
    "    return None\n",
    "\n",
    "\n",
    "def _infer_sampling_rate(time_values):\n",
    "    \"\"\"Infer sampling rate from a monotonic time vector in seconds.\"\"\"\n",
    "    time_values = np.asarray(time_values, dtype=float)\n",
    "    if len(time_values) < 3:\n",
    "        return None\n",
    "    dt = np.diff(time_values)\n",
    "    dt = dt[np.isfinite(dt) & (dt > 0)]\n",
    "    if len(dt) == 0:\n",
    "        return None\n",
    "    return float(1.0 / np.median(dt))\n",
    "\n",
    "\n",
    "def _resample_to_grid(df, time_col, target_time):\n",
    "    \"\"\"Resample all numeric columns of df to target_time using linear interpolation.\"\"\"\n",
    "    out = pd.DataFrame({\"time_sec\": target_time})\n",
    "    source_time = pd.to_numeric(df[time_col], errors=\"coerce\").values\n",
    "\n",
    "    for col in df.columns:\n",
    "        if col == time_col:\n",
    "            continue\n",
    "        series = pd.to_numeric(df[col], errors=\"coerce\")\n",
    "        if series.notna().sum() < 2:\n",
    "            continue\n",
    "        y = series.values\n",
    "        valid = np.isfinite(source_time) & np.isfinite(y)\n",
    "        if valid.sum() < 2:\n",
    "            continue\n",
    "        out[col] = np.interp(\n",
    "            target_time,\n",
    "            source_time[valid],\n",
    "            y[valid],\n",
    "            left=np.nan,\n",
    "            right=np.nan,\n",
    "        )\n",
    "\n",
    "    return out\n",
    "\n",
    "\n",
    "def synchronize_signals(cosmed_df, nirs_df, force_df):\n",
    "    \"\"\"\n",
    "    Synchronize signals using COSMED trigger timestamps.\n",
    "\n",
    "    Steps:\n",
    "    - Detect trigger events\n",
    "    - Align time axes\n",
    "    - Resample signals if needed\n",
    "    - Return synchronized datasets\n",
    "    \"\"\"\n",
    "    datasets = {\n",
    "        \"cosmed\": cosmed_df.copy(),\n",
    "        \"nirs\": nirs_df.copy(),\n",
    "        \"forces\": force_df.copy(),\n",
    "    }\n",
    "\n",
    "    aligned = {}\n",
    "    trigger_times = {}\n",
    "\n",
    "    for name, df in datasets.items():\n",
    "        time_col = _get_time_column(df)\n",
    "        if time_col is None:\n",
    "            raise ValueError(f\"No time column found for {name} dataframe.\")\n",
    "\n",
    "        df[time_col] = pd.to_numeric(df[time_col], errors=\"coerce\")\n",
    "        df = df.dropna(subset=[time_col]).sort_values(time_col).reset_index(drop=True)\n",
    "\n",
    "        trigger_time = _detect_trigger_time(df)\n",
    "        trigger_times[name] = trigger_time\n",
    "\n",
    "        if trigger_time is not None:\n",
    "            df[\"time_sec\"] = df[time_col] - trigger_time\n",
    "        else:\n",
    "            df[\"time_sec\"] = df[time_col] - df[time_col].iloc[0]\n",
    "\n",
    "        aligned[name] = df\n",
    "\n",
    "    if trigger_times[\"cosmed\"] is not None:\n",
    "        # COSMED trigger is the synchronization anchor by protocol design.\n",
    "        for name in [\"nirs\", \"forces\"]:\n",
    "            if trigger_times[name] is None:\n",
    "                shift = aligned[name][\"time_sec\"].iloc[0]\n",
    "                aligned[name][\"time_sec\"] = aligned[name][\"time_sec\"] - shift\n",
    "\n",
    "    if CONFIG[\"sampling_rates\"][\"cosmed\"] is None:\n",
    "        CONFIG[\"sampling_rates\"][\"cosmed\"] = _infer_sampling_rate(aligned[\"cosmed\"][\"time_sec\"])\n",
    "    if CONFIG[\"sampling_rates\"][\"nirs\"] is None:\n",
    "        CONFIG[\"sampling_rates\"][\"nirs\"] = _infer_sampling_rate(aligned[\"nirs\"][\"time_sec\"])\n",
    "    if CONFIG[\"sampling_rates\"][\"forces\"] is None:\n",
    "        CONFIG[\"sampling_rates\"][\"forces\"] = _infer_sampling_rate(aligned[\"forces\"][\"time_sec\"])\n",
    "\n",
    "    inferred_rates = [\n",
    "        rate for rate in CONFIG[\"sampling_rates\"].values() if isinstance(rate, (int, float))\n",
    "    ]\n",
    "    target_fs = min(inferred_rates) if inferred_rates else 1.0\n",
    "\n",
    "    t_start = max(\n",
    "        aligned[\"cosmed\"][\"time_sec\"].min(),\n",
    "        aligned[\"nirs\"][\"time_sec\"].min(),\n",
    "        aligned[\"forces\"][\"time_sec\"].min(),\n",
    "    )\n",
    "    t_end = min(\n",
    "        aligned[\"cosmed\"][\"time_sec\"].max(),\n",
    "        aligned[\"nirs\"][\"time_sec\"].max(),\n",
    "        aligned[\"forces\"][\"time_sec\"].max(),\n",
    "    )\n",
    "\n",
    "    if not np.isfinite(t_start) or not np.isfinite(t_end) or t_end <= t_start:\n",
    "        raise ValueError(\"Unable to create a valid common synchronized time window.\")\n",
    "\n",
    "    common_time = np.arange(t_start, t_end, 1.0 / target_fs)\n",
    "\n",
    "    cosmed_sync = _resample_to_grid(aligned[\"cosmed\"], \"time_sec\", common_time)\n",
    "    nirs_sync = _resample_to_grid(aligned[\"nirs\"], \"time_sec\", common_time)\n",
    "    force_sync = _resample_to_grid(aligned[\"forces\"], \"time_sec\", common_time)\n",
    "\n",
    "    return {\n",
    "        \"cosmed\": cosmed_sync,\n",
    "        \"nirs\": nirs_sync,\n",
    "        \"forces\": force_sync,\n",
    "        \"metadata\": {\n",
    "            \"sampling_rate_hz\": target_fs,\n",
    "            \"trigger_times\": trigger_times,\n",
    "        },\n",
    "    }\n",
    "\n",
    "\n",
    "def lowpass_filter(signal_values, cutoff, fs, order=4):\n",
    "    \"\"\"Apply Butterworth low-pass filter.\"\"\"\n",
    "    values = np.asarray(signal_values, dtype=float)\n",
    "    if values.size < 5 or fs is None or fs <= 0:\n",
    "        return values\n",
    "\n",
    "    nyquist = 0.5 * fs\n",
    "    normalized_cutoff = cutoff / nyquist\n",
    "    if normalized_cutoff <= 0 or normalized_cutoff >= 1:\n",
    "        return values\n",
    "\n",
    "    valid = np.isfinite(values)\n",
    "    if valid.sum() < 5:\n",
    "        return values\n",
    "\n",
    "    filled = values.copy()\n",
    "    if not np.all(valid):\n",
    "        idx = np.arange(values.size)\n",
    "        filled[~valid] = np.interp(idx[~valid], idx[valid], values[valid])\n",
    "\n",
    "    b, a = signal.butter(order, normalized_cutoff, btype=\"low\", analog=False)\n",
    "    filtered = signal.filtfilt(b, a, filled)\n",
    "\n",
    "    filtered[~valid] = np.nan\n",
    "    return filtered\n",
    "\n",
    "\n",
    "def compute_auc(signal_values, time_values):\n",
    "    \"\"\"Compute area under curve using trapezoidal rule.\"\"\"\n",
    "    y = np.asarray(signal_values, dtype=float)\n",
    "    t = np.asarray(time_values, dtype=float)\n",
    "    valid = np.isfinite(y) & np.isfinite(t)\n",
    "    if valid.sum() < 2:\n",
    "        return np.nan\n",
    "    return float(np.trapz(y[valid], t[valid]))\n",
    "\n",
    "\n",
    "def compute_steady_state_mean(signal_values, window_sec):\n",
    "    \"\"\"Compute mean of last N seconds.\"\"\"\n",
    "    values = np.asarray(signal_values, dtype=float)\n",
    "    values = values[np.isfinite(values)]\n",
    "    if values.size == 0:\n",
    "        return np.nan\n",
    "\n",
    "    fs_candidates = [\n",
    "        CONFIG[\"sampling_rates\"].get(\"cosmed\"),\n",
    "        CONFIG[\"sampling_rates\"].get(\"nirs\"),\n",
    "        CONFIG[\"sampling_rates\"].get(\"forces\"),\n",
    "    ]\n",
    "    fs_candidates = [f for f in fs_candidates if isinstance(f, (int, float)) and f > 0]\n",
    "    fs = fs_candidates[0] if fs_candidates else 1.0\n",
    "\n",
    "    n_samples = int(window_sec * fs)\n",
    "    if n_samples <= 0:\n",
    "        return np.nan\n",
    "\n",
    "    tail = values[-n_samples:] if values.size >= n_samples else values\n",
    "    return float(np.nanmean(tail))\n",
    "\n",
    "\n",
    "def compute_variability(signal_values):\n",
    "    \"\"\"Return std and coefficient of variation.\"\"\"\n",
    "    values = np.asarray(signal_values, dtype=float)\n",
    "    values = values[np.isfinite(values)]\n",
    "    if values.size == 0:\n",
    "        return {\"std\": np.nan, \"cv\": np.nan}\n",
    "\n",
    "    std = float(np.std(values, ddof=1)) if values.size > 1 else 0.0\n",
    "    mean_val = float(np.mean(values))\n",
    "    cv = float((std / mean_val) * 100.0) if mean_val != 0 else np.nan\n",
    "\n",
    "    return {\"std\": std, \"cv\": cv}\n",
    "\n",
    "\n",
    "def run_repeated_measures_anova(df):\n",
    "    \"\"\"Perform repeated-measures ANOVA.\"\"\"\n",
    "    required_cols = {\"subject\", \"condition\", \"value\"}\n",
    "    if not required_cols.issubset(df.columns):\n",
    "        missing = required_cols.difference(df.columns)\n",
    "        raise ValueError(f\"Missing required columns for ANOVA: {sorted(missing)}\")\n",
    "\n",
    "    from statsmodels.stats.anova import AnovaRM\n",
    "\n",
    "    clean_df = df.dropna(subset=[\"subject\", \"condition\", \"value\"]).copy()\n",
    "    model = AnovaRM(clean_df, depvar=\"value\", subject=\"subject\", within=[\"condition\"])\n",
    "    fitted = model.fit()\n",
    "    table = fitted.anova_table.reset_index().rename(columns={\"index\": \"effect\"})\n",
    "\n",
    "    if all(col in table.columns for col in [\"F Value\", \"Num DF\", \"Den DF\"]):\n",
    "        f_val = table[\"F Value\"].astype(float)\n",
    "        num_df = table[\"Num DF\"].astype(float)\n",
    "        den_df = table[\"Den DF\"].astype(float)\n",
    "        table[\"partial_eta_squared\"] = (f_val * num_df) / ((f_val * num_df) + den_df)\n",
    "\n",
    "    return table\n",
    "\n",
    "\n",
    "def compute_correlations(df):\n",
    "    \"\"\"Compute Pearson correlations.\"\"\"\n",
    "    numeric_df = df.select_dtypes(include=[np.number]).dropna(axis=1, how=\"all\")\n",
    "    if numeric_df.shape[1] < 2:\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    from scipy.stats import pearsonr\n",
    "\n",
    "    rows = []\n",
    "    cols = numeric_df.columns.tolist()\n",
    "    for i, col_i in enumerate(cols):\n",
    "        for col_j in cols[i + 1:]:\n",
    "            pair = numeric_df[[col_i, col_j]].dropna()\n",
    "            if len(pair) < 3:\n",
    "                r_val, p_val = np.nan, np.nan\n",
    "            else:\n",
    "                r_val, p_val = pearsonr(pair[col_i], pair[col_j])\n",
    "            rows.append(\n",
    "                {\n",
    "                    \"var_1\": col_i,\n",
    "                    \"var_2\": col_j,\n",
    "                    \"pearson_r\": r_val,\n",
    "                    \"p_value\": p_val,\n",
    "                    \"n\": len(pair),\n",
    "                }\n",
    "            )\n",
    "\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "\n",
    "def plot_time_series(df, time_col=\"time_sec\", signal_cols=None, title=\"Time Series\"):\n",
    "    \"\"\"Plot selected time-series signals.\"\"\"\n",
    "    if time_col not in df.columns:\n",
    "        raise ValueError(f\"Column '{time_col}' not found.\")\n",
    "\n",
    "    if signal_cols is None:\n",
    "        signal_cols = [\n",
    "            col for col in df.columns if col != time_col and pd.api.types.is_numeric_dtype(df[col])\n",
    "        ]\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(12, 5))\n",
    "    for col in signal_cols:\n",
    "        ax.plot(df[time_col], df[col], label=col, linewidth=1.5)\n",
    "\n",
    "    ax.set_title(title)\n",
    "    ax.set_xlabel(\"Time (s)\")\n",
    "    ax.set_ylabel(\"Signal\")\n",
    "    ax.legend(loc=\"best\")\n",
    "    ax.grid(True, alpha=0.3)\n",
    "    plt.tight_layout()\n",
    "    return fig, ax\n",
    "\n",
    "\n",
    "def plot_boxplots(df, value_col, group_col=\"condition\", title=None):\n",
    "    \"\"\"Plot boxplots for a metric across conditions.\"\"\"\n",
    "    if value_col not in df.columns or group_col not in df.columns:\n",
    "        raise ValueError(\"value_col and group_col must exist in dataframe.\")\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(8, 5))\n",
    "    sns.boxplot(data=df, x=group_col, y=value_col, ax=ax)\n",
    "    sns.stripplot(data=df, x=group_col, y=value_col, color=\"black\", alpha=0.5, ax=ax)\n",
    "\n",
    "    ax.set_title(title if title else f\"{value_col} by {group_col}\")\n",
    "    ax.set_xlabel(group_col)\n",
    "    ax.set_ylabel(value_col)\n",
    "    ax.grid(True, alpha=0.2)\n",
    "    plt.tight_layout()\n",
    "    return fig, ax\n",
    "\n",
    "\n",
    "def plot_correlation_heatmap(df, method=\"pearson\", title=\"Correlation Heatmap\"):\n",
    "    \"\"\"Plot heatmap of correlations between numeric variables.\"\"\"\n",
    "    numeric_df = df.select_dtypes(include=[np.number])\n",
    "    corr = numeric_df.corr(method=method)\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(8, 6))\n",
    "    sns.heatmap(corr, annot=True, fmt=\".2f\", cmap=\"coolwarm\", center=0, ax=ax)\n",
    "    ax.set_title(title)\n",
    "    plt.tight_layout()\n",
    "    return fig, ax\n",
    "\n",
    "\n",
    "def export_results(dataframe, filename):\n",
    "    \"\"\"Save CSV into results folder.\"\"\"\n",
    "    export_dir = Path(CONFIG[\"export_path\"])\n",
    "    export_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    output_path = export_dir / filename\n",
    "    dataframe.to_csv(output_path, index=False)\n",
    "\n",
    "    print(f\"✓ Results exported to: {output_path}\")\n",
    "    return output_path\n",
    "\n",
    "\n",
    "print(\"✓ Advanced utilities added (sections 2 to 7)\")"
   ]
