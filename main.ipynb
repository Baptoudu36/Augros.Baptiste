    "# ============================================================================\n",
    "# DERIVED METRICS CALCULATION FUNCTIONS\n",
    "# ============================================================================\n",
    "\n",
    "def calculate_energy_cost(vo2_exercise_mean, vo2_rest_mean, participant_mass_kg=None):\n",
    "    \"\"\"\n",
    "    Calculate exercise energy cost.\n",
    "    \n",
    "    Energy cost = VO2_exercise - VO2_rest\n",
    "    \n",
    "    If mass provided, also returns in mL/kg/min\n",
    "    \"\"\"\n",
    "    energy_cost_ml_min = vo2_exercise_mean - vo2_rest_mean\n",
    "    \n",
    "    result = {\n",
    "        'energy_cost_ml_min': energy_cost_ml_min,\n",
    "    }\n",
    "    \n",
    "    if participant_mass_kg is not None:\n",
    "        result['energy_cost_ml_kg_min'] = energy_cost_ml_min / participant_mass_kg\n",
    "    \n",
    "    return result\n",
    "\n",
    "\n",
    "def calculate_oxygen_pulse(vo2_mean, hr_mean):\n",
    "    \"\"\"\n",
    "    Calculate oxygen pulse.\n",
    "    \n",
    "    Oxygen pulse = VO2 / HR\n",
    "    \n",
    "    Represents the volume of O2 consumed per heartbeat.\n",
    "    \"\"\"\n",
    "    if hr_mean > 0:\n",
    "        return vo2_mean / hr_mean\n",
    "    return np.nan\n",
    "\n",
    "\n",
    "def detect_force_peaks(force_data, time_col='time_sec', force_col='total_force_N',\n",
    "                      height_threshold=None, distance_samples=100):\n",
    "    \"\"\"\n",
    "    Detect force peaks and calculate step frequency.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    force_data : DataFrame\n",
    "        Force data\n",
    "    time_col : str\n",
    "        Name of time column\n",
    "    force_col : str\n",
    "        Name of force column\n",
    "    height_threshold : float\n",
    "        Minimum height threshold for peak detection (if None, auto-calculated)\n",
    "    distance_samples : int\n",
    "        Minimum distance between peaks (in samples)\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    dict with:\n",
    "        - peak_indices: detected peak indices\n",
    "        - peak_times: peak times\n",
    "        - peak_values: peak values\n",
    "        - mean_peak_force: mean force of peaks\n",
    "        - step_frequency_hz: step frequency (Hz)\n",
    "        - step_frequency_bpm: step frequency (steps/min)\n",
    "    \"\"\"\n",
    "    force = force_data[force_col].values\n",
    "    time = force_data[time_col].values\n",
    "    \n",
    "    # Auto-calculate threshold if not provided (e.g.: median + 2*MAD)\n",
    "    if height_threshold is None:\n",
    "        median_force = np.median(force)\n",
    "        mad = np.median(np.abs(force - median_force))\n",
    "        height_threshold = median_force + 2 * mad\n",
    "    \n",
    "    # Detect peaks\n",
    "    peaks, properties = find_peaks(force, height=height_threshold, distance=distance_samples)\n",
    "    \n",
    "    if len(peaks) == 0:\n",
    "        print(\"  ⚠ No peaks detected, check threshold or data\")\n",
    "        return {\n",
    "            'peak_indices': [],\n",
    "            'peak_times': [],\n",
    "            'peak_values': [],\n",
    "            'mean_peak_force': np.nan,\n",
    "            'std_peak_force': np.nan,\n",
    "            'step_frequency_hz': np.nan,\n",
    "            'step_frequency_bpm': np.nan,\n",
    "            'n_peaks': 0\n",
    "        }\n",
    "    \n",
    "    peak_times = time[peaks]\n",
    "    peak_values = force[peaks]\n",
    "    \n",
    "    # Calculate step frequency from peak intervals\n",
    "    if len(peak_times) > 1:\n",
    "        intervals = np.diff(peak_times)\n",
    "        mean_interval = np.mean(intervals)\n",
    "        step_frequency_hz = 1.0 / mean_interval if mean_interval > 0 else np.nan\n",
    "        step_frequency_bpm = step_frequency_hz * 60 if not np.isnan(step_frequency_hz) else np.nan\n",
    "    else:\n",
    "        step_frequency_hz = np.nan\n",
    "        step_frequency_bpm = np.nan\n",
    "    \n",
    "    result = {\n",
    "        'peak_indices': peaks,\n",
    "        'peak_times': peak_times,\n",
    "        'peak_values': peak_values,\n",
    "        'mean_peak_force': np.mean(peak_values),\n",
    "        'std_peak_force': np.std(peak_values),\n",
    "        'step_frequency_hz': step_frequency_hz,\n",
    "        'step_frequency_bpm': step_frequency_bpm,\n",
    "        'n_peaks': len(peaks)\n",
    "    }\n",
    "    \n",
    "    print(f\"✓ {len(peaks)} peaks detected\")\n",
