   ],
   "source": [
    "# ============================================================================\n",
    "# TASK 2 : STATISTICAL ANALYSES\n",
    "# ============================================================================\n",
    "\n",
    "import itertools\n",
    "from scipy import stats\n",
    "\n",
    "required_vars = ['block_level_df', 'analysis_df']\n",
    "missing_vars = [name for name in required_vars if name not in globals()]\n",
    "if missing_vars:\n",
    "    raise RuntimeError(\n",
    "        \"Missing variables. Run the consolidation cell first: \"\n",
    "        + \", \".join(missing_vars)\n",
    "    )\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 1) NORMALITY TESTS (Shapiro-Wilk)\n",
    "# ---------------------------------------------------------------------------\n",
    "key_vars = ['VO2_ml_min', 'HR_bpm', 'SmO2_Quad', 'SmO2_Calf', 'Mean_Peak_Force']\n",
    "\n",
    "print(\"=\" * 80)\n",
    "print(\"NORMALITY TESTS (Shapiro-Wilk) - Block Level\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "normality_results = []\n",
    "for var in key_vars:\n",
    "    if var not in block_level_df.columns:\n",
    "        continue\n",
    "    values = block_level_df[var].dropna().values\n",
    "    if len(values) < 3:\n",
    "        p_value = np.nan\n",
    "        stat = np.nan\n",
    "    else:\n",
    "        stat, p_value = stats.shapiro(values)\n",
    "    normality_results.append({\n",
    "        'variable': var,\n",
    "        'n': len(values),\n",
    "        'W': stat,\n",
    "        'p_value': p_value,\n",
    "        'normal': bool(p_value > 0.05) if not np.isnan(p_value) else False\n",
    "    })\n",
    "\n",
    "normality_df = pd.DataFrame(normality_results)\n",
    "print(normality_df.to_string(index=False))\n",
    "\n",
    "# Normality flags\n",
    "normal_vo2 = bool(normality_df.loc[normality_df['variable'] == 'VO2_ml_min', 'normal'].iloc[0])\n",
    "normal_smo2_quad = bool(normality_df.loc[normality_df['variable'] == 'SmO2_Quad', 'normal'].iloc[0])\n",
    "normal_smo2_calf = bool(normality_df.loc[normality_df['variable'] == 'SmO2_Calf', 'normal'].iloc[0])\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 2) REPEATED-MEASURES ANOVA (Shoes A/B/C)\n",
    "# ---------------------------------------------------------------------------\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"REPEATED-MEASURES ANOVA (Condition: A/B/C)\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "# Aggregation by participant and condition\n",
    "if 'subject' not in block_level_df.columns:\n",
    "    block_level_df['subject'] = ['P{:02d}'.format(i + 1) for i in range(len(block_level_df))]\n",
    "\n",
    "agg_df = block_level_df.groupby(['subject', 'shoe_code'])[key_vars].mean().reset_index()\n",
    "agg_df = agg_df.rename(columns={'shoe_code': 'condition'})\n",
    "\n",
    "try:\n",
    "    from statsmodels.stats.anova import AnovaRM\n",
    "    statsmodels_available = True\n",
    "except Exception:\n",
    "    statsmodels_available = False\n",
    "\n",
    "try:\n",
    "    import pingouin as pg\n",
    "    pingouin_available = True\n",
    "except Exception:\n",
    "    pingouin_available = False\n",
    "\n",
    "anova_results = {}\n",
    "\n",
    "for var in key_vars:\n",
    "    if var not in agg_df.columns:\n",
    "        continue\n",
    "    print(f\"\\n-- {var} --\")\n",
    "\n",
    "    # Statsmodels ANOVA\n",
    "    if statsmodels_available:\n",
    "        try:\n",
    "            aov = AnovaRM(agg_df, depvar=var, subject='subject', within=['condition']).fit()\n",
    "            print(aov.summary())\n",
    "            anova_results[var] = aov\n",
    "        except Exception as e:\n",
    "            print(f\"ANOVA failed for {var}: {e}\")\n",
    "    else:\n",
    "        print(\"statsmodels not available, skipping ANOVA.\")\n",
    "\n",
    "    # Post-hoc with pingouin\n",
    "    if pingouin_available:\n",
    "        try:\n",
    "            posthoc = pg.pairwise_ttests(\n",
    "                dv=var,\n",
    "                within='condition',\n",
    "                subject='subject',\n",
    "                padjust='holm',\n",
    "                data=agg_df,\n",
    "                effsize='hedges'\n",
    "            )\n",
    "            print(\"Post-hoc (Holm):\")\n",
    "            display(posthoc[['A', 'B', 'T', 'p-corr', 'hedges']])\n",
    "        except Exception as e:\n",
    "            print(f\"Post-hoc failed for {var}: {e}\")\n",
    "    else:\n",
    "        # Fallback: paired t-tests\n",
    "        pairs = list(itertools.combinations(sorted(agg_df['condition'].unique()), 2))\n",
    "        p_vals = []\n",
    "        pair_names = []\n",
    "        for a, b in pairs:\n",
    "            a_vals = agg_df.loc[agg_df['condition'] == a, var].values\n",
    "            b_vals = agg_df.loc[agg_df['condition'] == b, var].values\n",
    "            if len(a_vals) == len(b_vals) and len(a_vals) > 1:\n",
    "                t_stat, p_val = stats.ttest_rel(a_vals, b_vals, nan_policy='omit')\n",
    "            else:\n",
    "                t_stat, p_val = np.nan, np.nan\n",
    "            p_vals.append(p_val)\n",
    "            pair_names.append(f\"{a} vs {b}\")\n",
    "        # Holm correction\n",
    "        p_vals_array = np.array(p_vals, dtype=float)\n",
    "        order = np.argsort(p_vals_array)\n",
    "        holm = np.full_like(p_vals_array, np.nan)\n",
    "        m = len(p_vals_array)\n",
    "        for i, idx in enumerate(order):\n",
    "            if np.isnan(p_vals_array[idx]):\n",
    "                continue\n",
    "            holm[idx] = min((m - i) * p_vals_array[idx], 1.0)\n",
    "        posthoc_df = pd.DataFrame({'pair': pair_names, 'p_raw': p_vals_array, 'p_holm': holm})\n",
    "        print(posthoc_df)\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 3) CORRELATIONS AND LINEAR REGRESSION\n",
    "# ---------------------------------------------------------------------------\n",
    "print(\"\\n\" + \"=\" * 80)\n",
    "print(\"CORRELATIONS AND REGRESSIONS (VO2 vs SmO2)\")\n",
    "print(\"=\" * 80)\n",
    "\n",
    "corr_method = 'pearson' if (normal_vo2 and normal_smo2_quad and normal_smo2_calf) else 'spearman'\n",
    "print(f\"Correlation method selected: {corr_method}\")\n",
    "\n",
    "vo2 = agg_df['VO2_ml_min'].values\n",
    "smo2_quad = agg_df['SmO2_Quad'].values\n",
    "smo2_calf = agg_df['SmO2_Calf'].values\n",
    "\n",
    "if corr_method == 'pearson':\n",
    "    r_quad, p_quad = stats.pearsonr(vo2, smo2_quad)\n",
    "    r_calf, p_calf = stats.pearsonr(vo2, smo2_calf)\n",
    "else:\n",
    "    r_quad, p_quad = stats.spearmanr(vo2, smo2_quad, nan_policy='omit')\n",
    "    r_calf, p_calf = stats.spearmanr(vo2, smo2_calf, nan_policy='omit')\n",
    "\n",
    "print(f\"VO2 vs SmO2_Quad: r = {r_quad:.3f}, p = {p_quad:.4f}\")\n",
    "print(f\"VO2 vs SmO2_Calf: r = {r_calf:.3f}, p = {p_calf:.4f}\")\n",
    "\n",
    "# Linear regressions\n",
    "try:\n",
    "    import statsmodels.api as sm\n",
    "    statsmodels_available = True\n",
    "except Exception:\n",
    "    statsmodels_available = False\n",
    "\n",
    "if statsmodels_available:\n",
    "    X_quad = sm.add_constant(agg_df['SmO2_Quad'])\n",
    "    X_calf = sm.add_constant(agg_df['SmO2_Calf'])\n",
    "    X_both = sm.add_constant(agg_df[['SmO2_Quad', 'SmO2_Calf']])\n",
    "\n",
    "    model_quad = sm.OLS(agg_df['VO2_ml_min'], X_quad, missing='drop').fit()\n",
    "    model_calf = sm.OLS(agg_df['VO2_ml_min'], X_calf, missing='drop').fit()\n",
    "    model_both = sm.OLS(agg_df['VO2_ml_min'], X_both, missing='drop').fit()\n",
    "\n",
    "    print(\"\\nRegression: VO2 ~ SmO2_Quad\")\n",
    "    print(model_quad.summary())\n",
    "\n",
    "    print(\"\\nRegression: VO2 ~ SmO2_Calf\")\n",
    "    print(model_calf.summary())\n",
    "\n",
    "    print(\"\\nRegression: VO2 ~ SmO2_Quad + SmO2_Calf\")\n",
    "    print(model_both.summary())\n",
    "else:\n",
    "    slope, intercept, r_value, p_value, stderr = stats.linregress(smo2_quad, vo2)\n",
    "    print(\"\\nRegression fallback (VO2 ~ SmO2_Quad)\")\n",
    "    print(f\"slope={slope:.4f}, intercept={intercept:.2f}, r={r_value:.3f}, p={p_value:.4f}\")"
   ]
  },
