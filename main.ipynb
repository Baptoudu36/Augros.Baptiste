    "\n",
    "try:\n",
    "    # Keep raw copies for reproducibility and fallback behavior.\n",
    "    k5_data_raw = k5_data.copy()\n",
    "    hr_data_raw = hr_data.copy()\n",
    "    nirs_data_raw = nirs_data.copy()\n",
