    "# ============================================================================\n",
    "# DATA LOADING FUNCTIONS\n",
    "# ============================================================================\n",
    "\n",
    "def load_k5_data(filepath):\n",
    "    \"\"\"\n",
    "    Load Cosmed K5 metabolic data.\n",
    "    Returns a DataFrame with standardized columns.\n",
    "    \"\"\"\n",
    "    # Read first line manually to get column names\n",
    "    with open(filepath, 'r', encoding='utf-8') as f:\n",
    "        first_line = f.readline()\n",
    "    \n",
    "    # Extract column names from first line\n",
    "    # Format: \"ID1;;;Test date;...;;t;F Resp;VC;VE;...\"\n",
    "    # Look for column 't' which marks the start of data\n",
    "    headers = first_line.strip().split(';')\n",
    "    t_index = headers.index('t') if 't' in headers else 9\n",
    "    headers = headers[t_index:]  # Keep only from 't' onwards\n",
    "    \n",
    "    # Load data skipping first 3 lines (header + units + info)\n",
    "    df = pd.read_csv(filepath, sep=';', skiprows=3, encoding='utf-8', on_bad_lines='skip', low_memory=False)\n",
    "    \n",
    "    # Keep only columns from position corresponding to 't'\n",
    "    df = df.iloc[:, t_index:]\n",
    "    df.columns = headers[:len(df.columns)]\n",
    "    \n",
    "    # Clean column names\n",
    "    df.columns = [str(col).strip() for col in df.columns]\n",
    "    \n",
    "    # Identify and rename important columns\n",
    "    columns_map = {}\n",
    "    for col in df.columns:\n",
    "        if col == 't':\n",
    "            columns_map[col] = 'time_sec'\n",
    "        elif col == 'VO2':\n",
    "            columns_map[col] = 'VO2_ml_min'\n",
    "        elif col == 'VCO2':\n",
    "            columns_map[col] = 'VCO2_ml_min'\n",
    "        elif col == 'QR':\n",
    "            columns_map[col] = 'RER'\n",
    "        elif col == 'VE':\n",
    "            columns_map[col] = 'VE_L_min'\n",
    "        elif col == 'F Resp':\n",
    "            columns_map[col] = 'Freq_Resp'\n",
    "        elif col == 'VC':\n",
    "            columns_map[col] = 'VT_L'\n",
    "        elif col == 'HR Echant.':\n",
    "            columns_map[col] = 'HR_bpm'\n",
    "    \n",
    "    df = df.rename(columns=columns_map)\n",
    "    \n",
    "    # Select available columns\n",
    "    cols_to_keep = ['time_sec', 'VO2_ml_min', 'VCO2_ml_min', 'RER', 'VE_L_min', \n",
    "                    'Freq_Resp', 'VT_L', 'HR_bpm']\n",
    "    cols_available = [col for col in cols_to_keep if col in df.columns]\n",
    "    \n",
    "    if not cols_available:\n",
    "        print(f\"  ⚠ Available columns in file: {list(df.columns)[:15]}\")\n",
    "        return pd.DataFrame()\n",
    "    \n",
    "    df = df[cols_available].copy()\n",
    "    \n",
    "    # Convert to numeric - handle European commas\n",
    "    for col in df.columns:\n",
    "        try:\n",
    "            if col == 'time_sec':\n",
    "                # Convert MM:SS format to seconds\n",
    "                def time_to_sec(t):\n",
    "                    try:\n",
    "                        t_str = str(t).strip()\n",
    "                        if ':' in t_str:\n",
    "                            parts = t_str.split(':')\n",
    "                            if len(parts) == 2:\n",
    "                                return int(parts[0]) * 60 + int(parts[1])\n",
    "                    except:\n",
    "                        pass\n",
    "                    return np.nan\n",
    "                df[col] = df[col].apply(time_to_sec)\n",
    "            else:\n",
    "                df[col] = df[col].astype(str).str.replace(',', '.').str.replace(' ', '')\n",
    "                df[col] = pd.to_numeric(df[col], errors='coerce')\n",
    "        except:\n",
    "            pass\n",
    "    \n",
    "    # Remove rows with NaN in time_sec\n",
    "    if 'time_sec' in df.columns:\n",
    "        df = df.dropna(subset=['time_sec']).reset_index(drop=True)\n",
    "    \n",
    "    print(f\"✓ K5 data loaded: {len(df)} samples\")\n",
    "    if len(df) > 0 and 'time_sec' in df.columns:\n",
    "        print(f\"  Duration: {df['time_sec'].max():.1f} seconds ({df['time_sec'].max()/60:.1f} minutes)\")\n",
    "    print(f\"  Columns: {', '.join(df.columns.tolist())}\")\n",
    "    \n",
    "    return df\n",
    "\n",
    "\n",
    "def load_hr_data(filepath):\n",
    "    \"\"\"\n",
    "    Load heart rate data.\n",
    "    \"\"\"\n",
    "    # Find data start line\n",
    "    skiprows = 0\n",
    "    with open(filepath, 'r', encoding='utf-8') as f:\n",
    "        for i, line in enumerate(f):\n",
    "            if 'Sample rate,Time,HR (bpm)' in line:\n",
    "                skiprows = i + 1\n",
    "                break\n",
    "    \n",
    "    df = pd.read_csv(filepath, skiprows=skiprows)\n",
    "    \n",
    "    # Convert HH:MM:SS time to seconds\n",
    "    def time_to_seconds(time_str):\n",
    "        try:\n",
    "            parts = str(time_str).split(':')\n",
    "            if len(parts) == 3:\n",
    "                h, m, s = parts\n",
    "                return int(h) * 3600 + int(m) * 60 + int(s)\n",
    "        except:\n",
    "            return np.nan\n",
    "        return np.nan\n",
    "    \n",
    "    df['time_sec'] = df.iloc[:, 1].apply(time_to_seconds)\n",
    "    df['HR_bpm'] = pd.to_numeric(df.iloc[:, 2], errors='coerce')\n",
    "    \n",
    "    df = df[['time_sec', 'HR_bpm']].dropna().reset_index(drop=True)\n",
    "    \n",
    "    print(f\"✓ HR data loaded: {len(df)} samples\")\n",
    "    if len(df) > 0:\n",
    "        print(f\"  Duration: {df['time_sec'].max():.1f} seconds ({df['time_sec'].max()/60:.1f} minutes)\")\n",
    "    \n",
    "    return df\n",
    "\n",
    "\n",
    "def load_nirs_data(filepath, skiprows=61):\n",
    "    \"\"\"\n",
    "    Load mNIRS data (Train.Red).\n",
    "    Returns a DataFrame with parameters from both sensors.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        df = pd.read_csv(filepath, skiprows=skiprows, low_memory=False)\n",
    "        \n",
    "        # Find time column\n",
    "        time_col = None\n",
    "        for col in df.columns:\n",
    "            if 'timestamp' in str(col).lower() and 'second' in str(col).lower():\n",
    "                time_col = col\n",
    "                break\n",
    "        \n",
    "        if time_col is None:\n",
    "            print(\"  ⚠ Time column not found in NIRS file\")\n",
    "            print(f\"  Available columns: {list(df.columns)[:10]}\")\n",
    "            return pd.DataFrame()\n",
    "        \n",
    "        df = df.rename(columns={time_col: 'time_sec'})\n",
    "        \n",
    "        # Identify NIRS columns by position\n",
    "        col_names = list(df.columns)\n",
    "        rename_map = {}\n",
    "        used_names = set()  # Avoid duplicates\n",
    "        \n",
    "        for idx, col in enumerate(col_names):\n",
    "            col_str = str(col).lower()\n",
    "            new_name = None\n",
    "            \n",
    "            # Quadriceps (FYER) - index < 12\n",
    "            if 'smo2' in col_str and idx < 12 and 'SmO2_Quad' not in used_names:\n",
    "                new_name = 'SmO2_Quad'\n",
    "            elif 'smo2' in col_str and idx >= 12 and 'SmO2_Calf' not in used_names:\n",
    "                new_name = 'SmO2_Calf'\n",
    "            elif 'hhb' in col_str and 'unfiltered' in col_str and idx < 12 and 'HHb_Quad' not in used_names:\n",
    "                new_name = 'HHb_Quad'\n",
    "            elif 'hhb' in col_str and 'unfiltered' in col_str and idx >= 12 and 'HHb_Calf' not in used_names:\n",
    "                new_name = 'HHb_Calf'\n",
    "            elif 'thb' in col_str and 'unfiltered' in col_str and idx < 12 and 'tHb_Quad' not in used_names:\n",
    "                new_name = 'tHb_Quad'\n",
    "            elif 'thb' in col_str and 'unfiltered' in col_str and idx >= 12 and 'tHb_Calf' not in used_names:\n",
    "                new_name = 'tHb_Calf'\n",
    "            elif 'hbdiff' in col_str and idx < 12 and 'HbDiff_Quad' not in used_names:\n",
    "                new_name = 'HbDiff_Quad'\n",
    "            elif 'hbdiff' in col_str and idx >= 12 and 'HbDiff_Calf' not in used_names:\n",
    "                new_name = 'HbDiff_Calf'\n",
    "            \n",
    "            if new_name:\n",
    "                rename_map[col] = new_name\n",
    "                used_names.add(new_name)\n",
    "        \n",
    "        df = df.rename(columns=rename_map)\n",
    "        \n",
    "        # Select columns\n",
    "        important_cols = ['time_sec', 'SmO2_Quad', 'SmO2_Calf', 'HHb_Quad', 'HHb_Calf', \n",
    "                         'tHb_Quad', 'tHb_Calf', 'HbDiff_Quad', 'HbDiff_Calf']\n",
    "        cols_to_keep = [col for col in important_cols if col in df.columns]\n",
    "        \n",
    "        if len(cols_to_keep) < 2:\n",
    "            print(\"  ⚠ Insufficient NIRS columns found\")\n",
    "            return pd.DataFrame()\n",
    "        \n",
    "        df = df[cols_to_keep].copy()\n",
    "        \n",
    "        # Convert to numeric\n",
    "        for col in df.columns:\n",
    "            try:\n",
    "                df[col] = pd.to_numeric(df[col], errors='coerce')\n",
    "            except:\n",
    "                pass\n",
    "        \n",
    "        df = df.dropna(subset=['time_sec']).reset_index(drop=True)\n",
    "        \n",
    "        print(f\"✓ NIRS data loaded: {len(df)} samples\")\n",
    "        if len(df) > 0:\n",
    "            print(f\"  Sampling rate: ~{len(df)/df['time_sec'].max():.1f} Hz\")\n",
    "        print(f\"  Columns: {', '.join(df.columns.tolist())}\")\n",
    "        \n",
    "        return df\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"  ❌ NIRS error: {e}\")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "\n",
    "def load_force_plate_data(filepath, calibration_factor=FORCE_CALIBRATION_FACTOR):\n",
    "    \"\"\"\n",
    "    Load force plate data.\n",
    "    Returns a DataFrame with 4 sensors and time.\n",
    "    Forces are converted from Volts to Newtons using the calibration factor.\n",
    "    \"\"\"\n",
    "    df = pd.read_csv(filepath, sep=';', skiprows=4, encoding='utf-8', on_bad_lines='skip')\n",
    "    \n",
    "    # Extract time and 4 sensors\n",
    "    time_col = df.iloc[:, 0].astype(str).str.replace(',', '.')\n",
    "    sensor1 = df.iloc[:, 1].astype(str).str.replace(',', '.')\n",
    "    sensor2 = df.iloc[:, 3].astype(str).str.replace(',', '.')\n",
    "    sensor3 = df.iloc[:, 5].astype(str).str.replace(',', '.')\n",
    "    sensor4 = df.iloc[:, 7].astype(str).str.replace(',', '.')\n",
    "    \n",
    "    # Create new DataFrame\n",
    "    fp_df = pd.DataFrame({\n",
    "        'time_sec': pd.to_numeric(time_col, errors='coerce'),\n",
    "        'sensor1_V': pd.to_numeric(sensor1, errors='coerce'),\n",
    "        'sensor2_V': pd.to_numeric(sensor2, errors='coerce'),\n",
    "        'sensor3_V': pd.to_numeric(sensor3, errors='coerce'),\n",
    "        'sensor4_V': pd.to_numeric(sensor4, errors='coerce')\n",
    "    })\n",
    "    \n",
    "    # Convert Volts to Newtons using calibration factor\n",
    "    fp_df['sensor1_N'] = fp_df['sensor1_V'] * calibration_factor\n",
    "    fp_df['sensor2_N'] = fp_df['sensor2_V'] * calibration_factor\n",
    "    fp_df['sensor3_N'] = fp_df['sensor3_V'] * calibration_factor\n",
    "    fp_df['sensor4_N'] = fp_df['sensor4_V'] * calibration_factor\n",
    "    \n",
    "    # Calculate total vertical force in Newtons\n",
    "    fp_df['total_force_N'] = fp_df[['sensor1_N', 'sensor2_N', 'sensor3_N', 'sensor4_N']].sum(axis=1)\n",
    "    \n",
    "    fp_df = fp_df.dropna().reset_index(drop=True)\n",
    "    \n",
    "    print(f\"✓ Force plate data loaded: {len(fp_df)} samples\")\n",
    "    if len(fp_df) > 1:\n",
    "        print(f\"  Sampling rate: {1/fp_df['time_sec'].diff().median():.0f} Hz\")\n",
    "    print(f\"  Force calibration: {calibration_factor} N/V\")\n",
    "    \n",
    "    return fp_df\n",
    "\n",
    "\n",
    "print(\"✓ Data loading functions defined\")\n"
   ]
