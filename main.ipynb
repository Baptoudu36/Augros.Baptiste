    "        hr_sorted[\"HR_bpm\"] = pd.to_numeric(hr_sorted[\"HR_bpm\"], errors=\"coerce\")\n",
    "        hr_sorted = hr_sorted.dropna().sort_values(\"time_sec\")\n",
    "\n",
    "        hr_time = hr_sorted[\"time_sec\"].values\n",
    "        hr_val = hr_sorted[\"HR_bpm\"].values\n",
    "        target_time = k5_sync[\"time_sec\"].values\n",
    "\n",
    "        if len(hr_time) >= 2:\n",
    "            hr_interp = np.interp(target_time, hr_time, hr_val, left=np.nan, right=np.nan)\n",
    "            if isinstance(target_fs, (int, float)) and target_fs > 0:\n",
    "                hr_interp = lowpass_filter(hr_interp, cutoff=CONFIG[\"filter_cutoff\"], fs=target_fs, order=4)\n",
    "            hr_data = pd.DataFrame({\"time_sec\": target_time, \"HR_bpm\": hr_interp})\n",
    "        else:\n",
    "            hr_data = hr_data_raw.copy()\n",
    "    else:\n",
    "        hr_data = hr_data_raw.copy()\n",
    "\n",
    "    # Keep the original variable names used by downstream cells.\n",
    "    k5_data = k5_sync\n",
    "    nirs_data = nirs_sync\n",
    "    fp_data = fp_sync\n",
    "\n",
    "    print(\"✓ Synchronization completed\")\n",
    "    print(f\"  Common sampling rate: {target_fs:.3f} Hz\" if isinstance(target_fs, (int, float)) else \"  Common sampling rate: n/a\")\n",
    "    print(f\"  K5 synchronized points: {len(k5_data)}\")\n",
    "    print(f\"  NIRS synchronized points: {len(nirs_data)}\")\n",
    "    print(f\"  Force synchronized points: {len(fp_data)}\")\n",
    "    print(f\"  HR aligned points: {len(hr_data)}\")\n",
    "\n",
    "except Exception as e:\n",
    "    print(f\"⚠ Preprocessing skipped due to error: {e}\")\n",
    "    print(\"  Using raw loaded data to preserve notebook execution.\")"
   ]
