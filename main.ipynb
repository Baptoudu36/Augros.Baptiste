    "from IPython.display import display\n",
    "\n",
    "print(\"\\nCOMPACT STATISTICAL SUMMARY\")\n",
    "\n",
    "\n",
    "def _show_table(title, dataframe, *, significant_only=False, max_rows=6):\n",
    "    if dataframe is None or dataframe.empty:\n",
    "        print(f\"{title}: no data\")\n",
    "        return\n",
    "\n",
    "    view = dataframe.copy()\n",
    "    if significant_only and \"significant\" in view.columns:\n",
    "        significant_view = view[view[\"significant\"] == True]\n",
    "        if not significant_view.empty:\n",
    "            view = significant_view\n",
    "\n",
    "    print(f\"\\n{title}\")\n",
    "    display(view.round(4).head(max_rows))\n",
    "\n",
    "\n",
    "_show_table(\"Condition summary (A / B / C)\", condition_summary_df)\n",
    "_show_table(\"Baseline comparison\", baseline_comparison_df)\n",
    "_show_table(\"Repeated-measures ANOVA\", anova_results_df)\n",
    "_show_table(\"Bonferroni post-hoc tests\", posthoc_results_df, significant_only=True)\n",
    "_show_table(\"Pairwise correlations\", correlation_results_df)\n",
    "_show_table(\"Friedman robustness check\", friedman_results_df)\n"
   ]
  },
